//@version=5
indicator("ICT OTE - Optimal Trade Entry (0.705)", overlay=true, max_boxes_count=500, max_lines_count=500)

// ===========================
// INPUT SETTINGS
// ===========================

// Webhook Settings
webhookUrl = input.string("", title="Webhook URL", group="Webhook Settings")

// OTE Level Settings
fibLevel = input.float(0.705, title="Fibonacci Retracement Level", minval=0.5, maxval=0.8, step=0.005, group="OTE Settings")
levelThickness = input.int(2, title="Level Line Thickness", minval=1, maxval=5, group="OTE Settings")

// Trend Settings
htfTimeframe = input.timeframe("D", title="Higher Timeframe for Trend", group="Trend Settings")
swingLookback = input.int(10, title="Swing Detection Lookback", minval=5, group="Trend Settings")
structurePeriod = input.int(20, title="Market Structure Period", minval=10, group="Trend Settings")

// Visual Settings
showOTELevel = input.bool(true, title="Show 0.705 Level", group="Visual Settings")
showSwingPoints = input.bool(true, title="Show Swing Points", group="Visual Settings")
showDealingRange = input.bool(true, title="Show Dealing Range", group="Visual Settings")

// Alert Settings
enableAlerts = input.bool(true, title="Enable Alerts", group="Alert Settings")

// ===========================
// MARKET STRUCTURE TREND DETECTION
// ===========================

// Function to detect market structure
getMarketStructure() =>
    var float[] highs = array.new_float(0)
    var float[] lows = array.new_float(0)
    
    // Detect swing highs and lows
    swingHigh = ta.pivothigh(high, swingLookback, swingLookback)
    swingLow = ta.pivotlow(low, swingLookback, swingLookback)
    
    // Store recent swing points
    if not na(swingHigh)
        array.push(highs, high[swingLookback])
        if array.size(highs) > 3
            array.shift(highs)
    
    if not na(swingLow)
        array.push(lows, low[swingLookback])
        if array.size(lows) > 3
            array.shift(lows)
    
    // Determine trend based on structure
    trend = 0
    
    if array.size(highs) >= 2 and array.size(lows) >= 2
        // Check for higher highs and higher lows (uptrend)
        higherHighs = array.get(highs, array.size(highs) - 1) > array.get(highs, array.size(highs) - 2)
        higherLows = array.get(lows, array.size(lows) - 1) > array.get(lows, array.size(lows) - 2)
        
        // Check for lower highs and lower lows (downtrend)
        lowerHighs = array.get(highs, array.size(highs) - 1) < array.get(highs, array.size(highs) - 2)
        lowerLows = array.get(lows, array.size(lows) - 1) < array.get(lows, array.size(lows) - 2)
        
        if higherHighs and higherLows
            trend := 1  // Uptrend
        else if lowerHighs and lowerLows
            trend := -1  // Downtrend
    
    trend

// Get current timeframe structure
currentTrend = getMarketStructure()

// Get higher timeframe trend for confirmation
htfClose = request.security(syminfo.tickerid, htfTimeframe, close)
htfHigh = request.security(syminfo.tickerid, htfTimeframe, high)
htfLow = request.security(syminfo.tickerid, htfTimeframe, low)

// Higher timeframe structure
htfHigherHigh = htfHigh > htfHigh[1] and htfHigh[1] > htfHigh[2]
htfHigherLow = htfLow > htfLow[1] and htfLow[1] > htfLow[2]
htfLowerHigh = htfHigh < htfHigh[1] and htfHigh[1] < htfHigh[2]
htfLowerLow = htfLow < htfLow[1] and htfLow[1] < htfLow[2]

htfUptrend = htfHigherHigh or htfHigherLow
htfDowntrend = htfLowerHigh or htfLowerLow

// Combined trend (both timeframes must agree)
uptrend = currentTrend == 1 and htfUptrend
downtrend = currentTrend == -1 and htfDowntrend

// ===========================
// SWING POINT DETECTION
// ===========================

// Function to detect swing highs and lows
isSwingHigh = ta.pivothigh(high, swingLookback, swingLookback)
isSwingLow = ta.pivotlow(low, swingLookback, swingLookback)

// Variables to store dealing range (swing points)
var float dealingRangeLow = na
var float dealingRangeHigh = na
var int dealingRangeLowBar = na
var int dealingRangeHighBar = na

// Update swing points
if not na(isSwingLow)
    dealingRangeLow := low[swingLookback]
    dealingRangeLowBar := bar_index - swingLookback

if not na(isSwingHigh)
    dealingRangeHigh := high[swingLookback]
    dealingRangeHighBar := bar_index - swingLookback

// Plot swing points
plotshape(showSwingPoints and not na(isSwingLow), "Swing Low", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(showSwingPoints and not na(isSwingHigh), "Swing High", shape.triangledown, location.abovebar, color.red, size=size.small)

// ===========================
// OTE LEVEL CALCULATION (0.705 ONLY)
// ===========================

// Calculate 0.705 level from dealing range
float oteLevel = na
var line oteLevelLine = na
var line dealingRangeHighLine = na
var line dealingRangeLowLine = na

// For UPTREND: Calculate 0.705 from swing low to swing high
if not na(dealingRangeLow) and not na(dealingRangeHigh) and dealingRangeLowBar < dealingRangeHighBar and uptrend
    swingRange = dealingRangeHigh - dealingRangeLow
    oteLevel := dealingRangeHigh - (swingRange * fibLevel)
    
    if showOTELevel
        // Update the line position to move with chart
        if not na(oteLevelLine)
            line.delete(oteLevelLine)
        if not na(dealingRangeHighLine)
            line.delete(dealingRangeHighLine)
        if not na(dealingRangeLowLine)
            line.delete(dealingRangeLowLine)
            
        // Create new lines that extend to the right
        oteLevelLine := line.new(dealingRangeLowBar, oteLevel, bar_index + 20, oteLevel, color=color.new(color.yellow, 0), width=levelThickness, style=line.style_solid, extend=extend.right)
        
        if showDealingRange
            dealingRangeHighLine := line.new(dealingRangeHighBar, dealingRangeHigh, bar_index + 20, dealingRangeHigh, color=color.new(color.green, 50), width=1, style=line.style_dashed, extend=extend.right)
            dealingRangeLowLine := line.new(dealingRangeLowBar, dealingRangeLow, bar_index + 20, dealingRangeLow, color=color.new(color.green, 50), width=1, style=line.style_dashed, extend=extend.right)

// For DOWNTREND: Calculate 0.705 from swing high to swing low
if not na(dealingRangeLow) and not na(dealingRangeHigh) and dealingRangeHighBar < dealingRangeLowBar and downtrend
    swingRange = dealingRangeHigh - dealingRangeLow
    oteLevel := dealingRangeLow + (swingRange * fibLevel)
    
    if showOTELevel
        // Update the line position to move with chart
        if not na(oteLevelLine)
            line.delete(oteLevelLine)
        if not na(dealingRangeHighLine)
            line.delete(dealingRangeHighLine)
        if not na(dealingRangeLowLine)
            line.delete(dealingRangeLowLine)
            
        // Create new lines that extend to the right
        oteLevelLine := line.new(dealingRangeHighBar, oteLevel, bar_index + 20, oteLevel, color=color.new(color.yellow, 0), width=levelThickness, style=line.style_solid, extend=extend.right)
        
        if showDealingRange
            dealingRangeHighLine := line.new(dealingRangeHighBar, dealingRangeHigh, bar_index + 20, dealingRangeHigh, color=color.new(color.red, 50), width=1, style=line.style_dashed, extend=extend.right)
            dealingRangeLowLine := line.new(dealingRangeLowBar, dealingRangeLow, bar_index + 20, dealingRangeLow, color=color.new(color.red, 50), width=1, style=line.style_dashed, extend=extend.right)

// ===========================
// ENTRY SIGNAL LOGIC (REVISED)
// ===========================

// BUY Signal: In uptrend, price taps 0.705 level and closes bullish (opposite color)
bool buySignal = false
float buyEntry = na
float buySL = na
float buyTP = na

if uptrend and not na(oteLevel) and not na(dealingRangeHigh)
    // Check if price tapped the 0.705 level
    tappedLevel = low <= oteLevel and low[1] > oteLevel
    
    // Check if candle closed bullish (green/opposite color) after tapping
    closedBullish = close > open
    
    // Price should NOT close below 0.705 level
    didNotCloseBelow = close >= oteLevel
    
    if tappedLevel and closedBullish and didNotCloseBelow
        buySignal := true
        buyEntry := close
        buySL := low  // SL below the rejection candle
        buyTP := dealingRangeHigh  // TP at dealing range high

// SELL Signal: In downtrend, price taps 0.705 level and closes bearish (opposite color)
bool sellSignal = false
float sellEntry = na
float sellSL = na
float sellTP = na

if downtrend and not na(oteLevel) and not na(dealingRangeLow)
    // Check if price tapped the 0.705 level
    tappedLevel = high >= oteLevel and high[1] < oteLevel
    
    // Check if candle closed bearish (red/opposite color) after tapping
    closedBearish = close < open
    
    // Price should NOT close above 0.705 level
    didNotCloseAbove = close <= oteLevel
    
    if tappedLevel and closedBearish and didNotCloseAbove
        sellSignal := true
        sellEntry := close
        sellSL := high  // SL above the rejection candle
        sellTP := dealingRangeLow  // TP at dealing range low

// ===========================
// VISUAL SIGNALS
// ===========================

plotshape(buySignal, "BUY Signal", shape.labelup, location.belowbar, color.new(color.green, 0), 
          text="BUY\n0.705", textcolor=color.white, size=size.normal)
plotshape(sellSignal, "SELL Signal", shape.labeldown, location.abovebar, color.new(color.red, 0), 
          text="SELL\n0.705", textcolor=color.white, size=size.normal)

// Plot entry, SL, and TP levels
var line buyEntryLine = na
var line buySLLine = na
var line buyTPLine = na
var line sellEntryLine = na
var line sellSLLine = na
var line sellTPLine = na

if buySignal
    // Delete old lines
    if not na(buyEntryLine)
        line.delete(buyEntryLine)
        line.delete(buySLLine)
        line.delete(buyTPLine)
    
    buyEntryLine := line.new(bar_index, buyEntry, bar_index + 10, buyEntry, color=color.blue, width=2, style=line.style_solid)
    buySLLine := line.new(bar_index, buySL, bar_index + 10, buySL, color=color.red, width=1, style=line.style_dashed)
    buyTPLine := line.new(bar_index, buyTP, bar_index + 10, buyTP, color=color.green, width=1, style=line.style_dashed)

if sellSignal
    // Delete old lines
    if not na(sellEntryLine)
        line.delete(sellEntryLine)
        line.delete(sellSLLine)
        line.delete(sellTPLine)
    
    sellEntryLine := line.new(bar_index, sellEntry, bar_index + 10, sellEntry, color=color.blue, width=2, style=line.style_solid)
    sellSLLine := line.new(bar_index, sellSL, bar_index + 10, sellSL, color=color.red, width=1, style=line.style_dashed)
    sellTPLine := line.new(bar_index, sellTP, bar_index + 10, sellTP, color=color.green, width=1, style=line.style_dashed)

// ===========================
// WEBHOOK ALERTS
// ===========================

// BUY Alert
if buySignal and enableAlerts
    alertMessage = '{\n' +
         '  "symbol": "' + syminfo.ticker + '",\n' +
         '  "type": "BUY",\n' +
         '  "indicator": "ote_0705",\n' +
         '  "entry": "' + str.tostring(buyEntry) + '",\n' +
         '  "stopLoss": "' + str.tostring(buySL) + '",\n' +
         '  "takeProfit": "' + str.tostring(buyTP) + '"\n' +
         '}'
    
    alert(alertMessage, alert.freq_once_per_bar_close)

// SELL Alert
if sellSignal and enableAlerts
    alertMessage = '{\n' +
         '  "symbol": "' + syminfo.ticker + '",\n' +
         '  "type": "SELL",\n' +
         '  "indicator": "ote_0705",\n' +
         '  "entry": "' + str.tostring(sellEntry) + '",\n' +
         '  "stopLoss": "' + str.tostring(sellSL) + '",\n' +
         '  "takeProfit": "' + str.tostring(sellTP) + '"\n' +
         '}'
    
    alert(alertMessage, alert.freq_once_per_bar_close)

// ===========================
// INFORMATION TABLE
// ===========================

var table infoTable = table.new(position.top_right, 2, 7, bgcolor=color.new(color.gray, 90), border_width=1, border_color=color.gray)

if barstate.islast
    table.cell(infoTable, 0, 0, "OTE 0.705", text_color=color.white, text_size=size.normal)
    table.cell(infoTable, 1, 0, "", text_color=color.white)
    
    table.cell(infoTable, 0, 1, "HTF Trend", text_color=color.white)
    table.cell(infoTable, 1, 1, htfUptrend ? "UP" : htfDowntrend ? "DOWN" : "NEUTRAL", 
               text_color=htfUptrend ? color.green : htfDowntrend ? color.red : color.gray)
    
    table.cell(infoTable, 0, 2, "Current Trend", text_color=color.white)
    table.cell(infoTable, 1, 2, uptrend ? "UPTREND" : downtrend ? "DOWNTREND" : "NEUTRAL", 
               text_color=uptrend ? color.green : downtrend ? color.red : color.gray)
    
    table.cell(infoTable, 0, 3, "Fib Level", text_color=color.white)
    table.cell(infoTable, 1, 3, str.tostring(fibLevel * 100) + "%", text_color=color.yellow)
    
    table.cell(infoTable, 0, 4, "0.705 Level", text_color=color.white)
    table.cell(infoTable, 1, 4, not na(oteLevel) ? str.tostring(oteLevel, format.mintick) : "N/A", text_color=color.yellow)
    
    table.cell(infoTable, 0, 5, "Range High", text_color=color.white)
    table.cell(infoTable, 1, 5, not na(dealingRangeHigh) ? str.tostring(dealingRangeHigh, format.mintick) : "N/A", 
               text_color=uptrend ? color.green : color.red)
    
    table.cell(infoTable, 0, 6, "Range Low", text_color=color.white)
    table.cell(infoTable, 1, 6, not na(dealingRangeLow) ? str.tostring(dealingRangeLow, format.mintick) : "N/A", 
               text_color=uptrend ? color.green : color.red)

//@version=5
indicator("ICT OTE Advanced - Optimal Trade Entry", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500)

// ============================================================================
// ICT OPTIMAL TRADE ENTRY (OTE) - ADVANCED INDICATOR
// 
// Features:
// ✅ OTE Zone Detection (0.62-0.79 Fibonacci)
// ✅ Liquidity Sweep Detection (Equal Highs/Lows)
// ✅ Fair Value Gap (FVG) Identification
// ✅ Order Block Detection
// ✅ Market Structure Shift (MSS/BOS)
// ✅ Premium/Discount Zones
// ✅ Kill Zone Session Filters
// ✅ Multi-timeframe Trend Alignment
// ✅ Complete Visual System
// ============================================================================

// ==================== INPUTS ====================

// Core Settings
pivotLength = input.int(10, "Pivot Length (Dealing Range)", minval=5, maxval=30, group="📊 Core Settings")
lookbackBars = input.int(100, "Lookback Bars", minval=50, maxval=500, group="📊 Core Settings")

// OTE Settings
showOTEZone = input.bool(true, "Show OTE Zone (0.62-0.79)", group="🎯 OTE Settings")
showEquilibrium = input.bool(true, "Show 50% Equilibrium", group="🎯 OTE Settings")
showPreciseOTE = input.bool(true, "Show 0.705 Precise OTE", group="🎯 OTE Settings")
showTargets = input.bool(true, "Show Extension Targets", group="🎯 OTE Settings")

// Liquidity Settings
detectLiquidity = input.bool(true, "Detect Liquidity Sweeps", group="💧 Liquidity")
equalLevelTolerance = input.float(0.1, "Equal High/Low Tolerance %", minval=0.01, maxval=1.0, group="💧 Liquidity")
showEqualLevels = input.bool(true, "Show Equal Highs/Lows", group="💧 Liquidity")

// Fair Value Gap Settings
detectFVG = input.bool(true, "Detect Fair Value Gaps", group="⚡ Fair Value Gaps")
fvgExtend = input.int(20, "FVG Extension Bars", minval=5, maxval=100, group="⚡ Fair Value Gaps")

// Order Block Settings
detectOB = input.bool(true, "Detect Order Blocks", group="📦 Order Blocks")
obExtend = input.int(20, "Order Block Extension Bars", minval=5, maxval=100, group="📦 Order Blocks")

// Market Structure Settings
detectMSS = input.bool(true, "Detect Market Structure Shift", group="📈 Market Structure")
showBOS = input.bool(true, "Show Break of Structure", group="📈 Market Structure")

// Session/Kill Zone Settings
useKillZone = input.bool(false, "Filter by Kill Zones", group="⏰ Sessions")
londonKillZone = input.bool(true, "London Kill Zone (2-5 AM EST)", group="⏰ Sessions")
nyKillZone = input.bool(true, "NY Kill Zone (8-11 AM EST)", group="⏰ Sessions")

// Trend Filter
trendMA = input.int(50, "Trend Filter EMA", minval=20, maxval=200, group="📊 Trend Filter")
useTrendFilter = input.bool(true, "Use Trend Filter", group="📊 Trend Filter")

// Visual Settings
bullColor = input.color(#00ff88, "Bullish Color", group="🎨 Colors")
bearColor = input.color(#ff4444, "Bearish Color", group="🎨 Colors")
neutralColor = input.color(#888888, "Neutral Color", group="🎨 Colors")

// ==================== ICT FIBONACCI LEVELS ====================
fib_0 = 0.0        // 0% (High/Low)
fib_236 = 0.236    // 23.6%
fib_382 = 0.382    // 38.2%
fib_50 = 0.5       // 50% Equilibrium
fib_62 = 0.62      // 62% OTE Start
fib_705 = 0.705    // 70.5% Optimal Entry
fib_79 = 0.79      // 79% OTE End
fib_100 = 1.0      // 100% Full Retracement
fib_n50 = -0.5     // -50% Target 1
fib_n100 = -1.0    // -100% Target 2
fib_n200 = -2.0    // -200% Symmetrical

// ==================== TREND FILTER ====================
ema = ta.ema(close, trendMA)
bullishTrend = close > ema and ema > ema[5]
bearishTrend = close < ema and ema < ema[5]

// ==================== KILL ZONE DETECTION ====================
inKillZone() =>
    if not useKillZone
        true
    else
        h = hour(time, "America/New_York")
        inLondon = londonKillZone and (h >= 2 and h < 5)
        inNY = nyKillZone and (h >= 8 and h < 11)
        inLondon or inNY

// ==================== PIVOT DETECTION ====================
pivotHigh = ta.pivothigh(high, pivotLength, pivotLength)
pivotLow = ta.pivotlow(low, pivotLength, pivotLength)

// ==================== EQUAL HIGHS/LOWS DETECTION ====================
var float[] equalHighs = array.new_float()
var float[] equalLows = array.new_float()
var int[] equalHighBars = array.new_int()
var int[] equalLowBars = array.new_int()

if detectLiquidity and showEqualLevels
    // Detect Equal Highs
    if not na(pivotHigh)
        currentHigh = pivotHigh[pivotLength]
        tolerance = currentHigh * (equalLevelTolerance / 100)
        
        // Check for equal highs
        for i = 0 to array.size(equalHighs) - 1
            if math.abs(array.get(equalHighs, i) - currentHigh) <= tolerance
                // Found equal high - mark it
                line.new(array.get(equalHighBars, i), array.get(equalHighs, i), bar_index - pivotLength, currentHigh, color=color.new(bearColor, 50), width=2, style=line.style_dotted)
        
        array.push(equalHighs, currentHigh)
        array.push(equalHighBars, bar_index - pivotLength)
        
        // Limit array size
        if array.size(equalHighs) > 10
            array.shift(equalHighs)
            array.shift(equalHighBars)
    
    // Detect Equal Lows
    if not na(pivotLow)
        currentLow = pivotLow[pivotLength]
        tolerance = currentLow * (equalLevelTolerance / 100)
        
        // Check for equal lows
        for i = 0 to array.size(equalLows) - 1
            if math.abs(array.get(equalLows, i) - currentLow) <= tolerance
                // Found equal low - mark it
                line.new(array.get(equalLowBars, i), array.get(equalLows, i), bar_index - pivotLength, currentLow, color=color.new(bullColor, 50), width=2, style=line.style_dotted)
        
        array.push(equalLows, currentLow)
        array.push(equalLowBars, bar_index - pivotLength)
        
        // Limit array size
        if array.size(equalLows) > 10
            array.shift(equalLows)
            array.shift(equalLowBars)

// ==================== LIQUIDITY SWEEP DETECTION ====================
var bool bullLiqSweep = false
var bool bearLiqSweep = false
var float sweepLevel = na

if detectLiquidity
    // Bullish Sweep (sweep below equal lows)
    for i = 0 to array.size(equalLows) - 1
        lowLevel = array.get(equalLows, i)
        if low < lowLevel and close > lowLevel
            bullLiqSweep := true
            sweepLevel := lowLevel
            label.new(bar_index, low, "💧 SWEEP", color=color.new(bullColor, 0), textcolor=color.white, style=label.style_label_up, size=size.tiny)
    
    // Bearish Sweep (sweep above equal highs)
    for i = 0 to array.size(equalHighs) - 1
        highLevel = array.get(equalHighs, i)
        if high > highLevel and close < highLevel
            bearLiqSweep := true
            sweepLevel := highLevel
            label.new(bar_index, high, "💧 SWEEP", color=color.new(bearColor, 0), textcolor=color.white, style=label.style_label_down, size=size.tiny)

// ==================== FAIR VALUE GAP (FVG) DETECTION ====================
// Bullish FVG: Gap between candle 1 high and candle 3 low
bullFVG = detectFVG and (low > high[2])
bullFVGTop = bullFVG ? low : na
bullFVGBottom = bullFVG ? high[2] : na

// Bearish FVG: Gap between candle 1 low and candle 3 high
bearFVG = detectFVG and (high < low[2])
bearFVGTop = bearFVG ? low[2] : na
bearFVGBottom = bearFVG ? high : na

// Draw FVGs
if bullFVG
    box.new(bar_index - 2, bullFVGBottom, bar_index + fvgExtend, bullFVGTop, border_color=color.new(bullColor, 70), bgcolor=color.new(bullColor, 90), border_width=1, text="FVG", text_color=color.new(bullColor, 30), text_size=size.tiny)

if bearFVG
    box.new(bar_index - 2, bearFVGBottom, bar_index + fvgExtend, bearFVGTop, border_color=color.new(bearColor, 70), bgcolor=color.new(bearColor, 90), border_width=1, text="FVG", text_color=color.new(bearColor, 30), text_size=size.tiny)

// ==================== ORDER BLOCK DETECTION ====================
// Bullish OB: Last bearish candle before bullish displacement
bullDisplacement = (close > open) and (close - open) > (ta.atr(14) * 1.5)
var float bullOBTop = na
var float bullOBBottom = na
var int bullOBBar = na

if detectOB and bullDisplacement and close[1] < open[1]
    bullOBTop := open[1]
    bullOBBottom := close[1]
    bullOBBar := bar_index - 1
    box.new(bullOBBar, bullOBBottom, bar_index + obExtend, bullOBTop, border_color=color.new(bullColor, 60), bgcolor=color.new(bullColor, 85), border_width=2, text="OB", text_color=color.new(bullColor, 20), text_size=size.small)

// Bearish OB: Last bullish candle before bearish displacement
bearDisplacement = (close < open) and (open - close) > (ta.atr(14) * 1.5)
var float bearOBTop = na
var float bearOBBottom = na
var int bearOBBar = na

if detectOB and bearDisplacement and close[1] > open[1]
    bearOBTop := close[1]
    bearOBBottom := open[1]
    bearOBBar := bar_index - 1
    box.new(bearOBBar, bearOBBottom, bar_index + obExtend, bearOBTop, border_color=color.new(bearColor, 60), bgcolor=color.new(bearColor, 85), border_width=2, text="OB", text_color=color.new(bearColor, 20), text_size=size.small)

// ==================== MARKET STRUCTURE SHIFT (MSS) ====================
var float lastHigh = na
var float lastLow = na

// Update swing points
if not na(pivotHigh)
    lastHigh := pivotHigh[pivotLength]

if not na(pivotLow)
    lastLow := pivotLow[pivotLength]

// Detect MSS
bullMSS = detectMSS and not na(lastHigh) and close > lastHigh and close[1] <= lastHigh
bearMSS = detectMSS and not na(lastLow) and close < lastLow and close[1] >= lastLow

// Plot MSS
if bullMSS
    label.new(bar_index, low, "MSS ⬆", color=color.new(bullColor, 0), textcolor=color.white, style=label.style_label_up, size=size.small)

if bearMSS
    label.new(bar_index, high, "MSS ⬇", color=color.new(bearColor, 0), textcolor=color.white, style=label.style_label_down, size=size.small)

// ==================== BULLISH OTE SETUP ====================
var float bull_RangeLow = na
var float bull_RangeHigh = na
var int bull_RangeLowBar = na
var int bull_RangeHighBar = na
var bool bull_SetupActive = false

// Identify dealing range LOW
if not na(pivotLow) and (na(bull_RangeLow) or pivotLow[pivotLength] < bull_RangeLow)
    bull_RangeLow := pivotLow[pivotLength]
    bull_RangeLowBar := bar_index - pivotLength

// Identify dealing range HIGH
if not na(bull_RangeLow) and not na(pivotHigh) and pivotHigh[pivotLength] > bull_RangeLow
    if na(bull_RangeHigh) or pivotHigh[pivotLength] > bull_RangeHigh
        bull_RangeHigh := pivotHigh[pivotLength]
        bull_RangeHighBar := bar_index - pivotLength
        bull_SetupActive := true

// Calculate Bullish OTE Levels
float bull_Range = bull_RangeHigh - bull_RangeLow

float bull_Fib0 = bull_SetupActive ? bull_RangeHigh : na
float bull_Fib50 = bull_SetupActive ? bull_RangeLow + (bull_Range * fib_50) : na
float bull_Fib62 = bull_SetupActive ? bull_RangeLow + (bull_Range * fib_62) : na
float bull_Fib705 = bull_SetupActive ? bull_RangeLow + (bull_Range * fib_705) : na
float bull_Fib79 = bull_SetupActive ? bull_RangeLow + (bull_Range * fib_79) : na
float bull_Fib100 = bull_SetupActive ? bull_RangeLow : na
float bull_Target1 = bull_SetupActive ? bull_RangeHigh + (bull_Range * 0.5) : na
float bull_Target2 = bull_SetupActive ? bull_RangeHigh + bull_Range : na

// Check for bullish entry conditions
bool bull_InOTEZone = bull_SetupActive and low <= bull_Fib79 and low >= bull_Fib62
bool bull_InPremium = close > bull_Fib50  // Above equilibrium = premium
bool bull_InDiscount = close < bull_Fib50  // Below equilibrium = discount (better for long)
bool bull_TrendOK = useTrendFilter ? bullishTrend : true
bool bull_SessionOK = inKillZone()

bool bull_EntrySignal = bull_InOTEZone and bull_InDiscount and bull_TrendOK and bull_SessionOK

// Reset on structure break
if bull_SetupActive and not na(pivotLow) and pivotLow[pivotLength] < bull_RangeLow - (bull_Range * 0.1)
    bull_SetupActive := false
    bull_RangeLow := na
    bull_RangeHigh := na

// ==================== BEARISH OTE SETUP ====================
var float bear_RangeHigh = na
var float bear_RangeLow = na
var int bear_RangeHighBar = na
var int bear_RangeLowBar = na
var bool bear_SetupActive = false

// Identify dealing range HIGH
if not na(pivotHigh) and (na(bear_RangeHigh) or pivotHigh[pivotLength] > bear_RangeHigh)
    bear_RangeHigh := pivotHigh[pivotLength]
    bear_RangeHighBar := bar_index - pivotLength

// Identify dealing range LOW
if not na(bear_RangeHigh) and not na(pivotLow) and pivotLow[pivotLength] < bear_RangeHigh
    if na(bear_RangeLow) or pivotLow[pivotLength] < bear_RangeLow
        bear_RangeLow := pivotLow[pivotLength]
        bear_RangeLowBar := bar_index - pivotLength
        bear_SetupActive := true

// Calculate Bearish OTE Levels
float bear_Range = bear_RangeHigh - bear_RangeLow

float bear_Fib0 = bear_SetupActive ? bear_RangeLow : na
float bear_Fib50 = bear_SetupActive ? bear_RangeHigh - (bear_Range * fib_50) : na
float bear_Fib62 = bear_SetupActive ? bear_RangeHigh - (bear_Range * fib_62) : na
float bear_Fib705 = bear_SetupActive ? bear_RangeHigh - (bear_Range * fib_705) : na
float bear_Fib79 = bear_SetupActive ? bear_RangeHigh - (bear_Range * fib_79) : na
float bear_Fib100 = bear_SetupActive ? bear_RangeHigh : na
float bear_Target1 = bear_SetupActive ? bear_RangeLow - (bear_Range * 0.5) : na
float bear_Target2 = bear_SetupActive ? bear_RangeLow - bear_Range : na

// Check for bearish entry conditions
bool bear_InOTEZone = bear_SetupActive and high >= bear_Fib62 and high <= bear_Fib79
bool bear_InPremium = close > bear_Fib50  // Above equilibrium = premium (better for short)
bool bear_InDiscount = close < bear_Fib50
bool bear_TrendOK = useTrendFilter ? bearishTrend : true
bool bear_SessionOK = inKillZone()

bool bear_EntrySignal = bear_InOTEZone and bear_InPremium and bear_TrendOK and bear_SessionOK

// Reset on structure break
if bear_SetupActive and not na(pivotHigh) and pivotHigh[pivotLength] > bear_RangeHigh + (bear_Range * 0.1)
    bear_SetupActive := false
    bear_RangeHigh := na
    bear_RangeLow := na

// ==================== VISUALS ====================

// Trend EMA
plot(ema, "Trend EMA", color.new(color.yellow, 60), 2)

// --- BULLISH OTE ---
if showOTEZone and bull_SetupActive
    // OTE Zone Fill
    p1 = plot(bull_Fib79, "OTE 79%", color.new(bullColor, 0), 2)
    p2 = plot(bull_Fib62, "OTE 62%", color.new(bullColor, 0), 2)
    fill(p1, p2, color.new(bullColor, 85), title="Bull OTE Zone")

if showEquilibrium
    plot(bull_Fib50, "50% EQ", color.new(color.gray, 50), 1, plot.style_circles)

if showPreciseOTE
    plot(bull_Fib705, "70.5% OTE", color.new(bullColor, 30), 2, plot.style_cross)

if showTargets
    plot(bull_Target1, "Target 1", color.new(color.aqua, 50), 1, plot.style_circles)
    plot(bull_Target2, "Target 2", color.new(color.blue, 50), 1, plot.style_circles)

// --- BEARISH OTE ---
if showOTEZone and bear_SetupActive
    // OTE Zone Fill
    p3 = plot(bear_Fib62, "OTE 62%", color.new(bearColor, 0), 2)
    p4 = plot(bear_Fib79, "OTE 79%", color.new(bearColor, 0), 2)
    fill(p3, p4, color.new(bearColor, 85), title="Bear OTE Zone")

if showEquilibrium
    plot(bear_Fib50, "50% EQ", color.new(color.gray, 50), 1, plot.style_circles)

if showPreciseOTE
    plot(bear_Fib705, "70.5% OTE", color.new(bearColor, 30), 2, plot.style_cross)

if showTargets
    plot(bear_Target1, "Target 1", color.new(color.fuchsia, 50), 1, plot.style_circles)
    plot(bear_Target2, "Target 2", color.new(color.purple, 50), 1, plot.style_circles)

// Premium/Discount Zones
bgcolor(bull_SetupActive and bull_InDiscount ? color.new(bullColor, 97) : na, title="Discount Zone")
bgcolor(bear_SetupActive and bear_InPremium ? color.new(bearColor, 97) : na, title="Premium Zone")

// Entry Signals
if bull_EntrySignal
    label.new(bar_index, low, "🎯 LONG OTE\n" + str.tostring(close, "#.####"), color=color.new(bullColor, 0), textcolor=color.white, style=label.style_label_up, size=size.normal)
    alert("LONG OTE Entry at " + str.tostring(close), alert.freq_once_per_bar)

if bear_EntrySignal
    label.new(bar_index, high, "🎯 SHORT OTE\n" + str.tostring(close, "#.####"), color=color.new(bearColor, 0), textcolor=color.white, style=label.style_label_down, size=size.normal)
    alert("SHORT OTE Entry at " + str.tostring(close), alert.freq_once_per_bar)

// ==================== STATUS TABLE ====================
var table t = table.new(position.top_right, 2, 8, border_width=1)

if barstate.islast
    // Header
    table.cell(t, 0, 0, "ICT OTE ADVANCED", bgcolor=color.new(color.blue, 60), text_color=color.white, text_size=size.normal)
    table.cell(t, 1, 0, "STATUS", bgcolor=color.new(color.blue, 60), text_color=color.white, text_size=size.normal)
    
    // Trend
    table.cell(t, 0, 1, "Trend", text_color=color.white, text_size=size.small)
    trendText = bullishTrend ? "BULL ⬆" : bearishTrend ? "BEAR ⬇" : "NEUTRAL"
    trendBg = bullishTrend ? color.new(bullColor, 70) : bearishTrend ? color.new(bearColor, 70) : color.new(neutralColor, 80)
    table.cell(t, 1, 1, trendText, bgcolor=trendBg, text_color=color.white, text_size=size.small)
    
    // Kill Zone
    table.cell(t, 0, 2, "Kill Zone", text_color=color.white, text_size=size.small)
    kzStatus = inKillZone() ? "ACTIVE ⚡" : "Inactive"
    kzBg = inKillZone() ? color.new(color.orange, 70) : color.new(neutralColor, 85)
    table.cell(t, 1, 2, kzStatus, bgcolor=kzBg, text_color=color.white, text_size=size.small)
    
    // Long Setup
    table.cell(t, 0, 3, "LONG OTE", text_color=color.white, text_size=size.small)
    longStatus = bull_SetupActive ? (bull_InOTEZone ? "IN ZONE 🎯" : "WAITING") : "No Setup"
    longBg = bull_SetupActive ? (bull_InOTEZone ? color.new(bullColor, 60) : color.new(bullColor, 80)) : color.new(neutralColor, 85)
    table.cell(t, 1, 3, longStatus, bgcolor=longBg, text_color=color.white, text_size=size.small)
    
    // Short Setup
    table.cell(t, 0, 4, "SHORT OTE", text_color=color.white, text_size=size.small)
    shortStatus = bear_SetupActive ? (bear_InOTEZone ? "IN ZONE 🎯" : "WAITING") : "No Setup"
    shortBg = bear_SetupActive ? (bear_InOTEZone ? color.new(bearColor, 60) : color.new(bearColor, 80)) : color.new(neutralColor, 85)
    table.cell(t, 1, 4, shortStatus, bgcolor=shortBg, text_color=color.white, text_size=size.small)
    
    // FVG
    table.cell(t, 0, 5, "FVG", text_color=color.white, text_size=size.small)
    fvgStatus = bullFVG ? "BULL ⬆" : bearFVG ? "BEAR ⬇" : "None"
    fvgBg = bullFVG ? color.new(bullColor, 70) : bearFVG ? color.new(bearColor, 70) : color.new(neutralColor, 85)
    table.cell(t, 1, 5, fvgStatus, bgcolor=fvgBg, text_color=color.white, text_size=size.small)
    
    // MSS
    table.cell(t, 0, 6, "MSS", text_color=color.white, text_size=size.small)
    mssStatus = bullMSS ? "BULL ⬆" : bearMSS ? "BEAR ⬇" : "None"
    mssBg = bullMSS ? color.new(bullColor, 70) : bearMSS ? color.new(bearColor, 70) : color.new(neutralColor, 85)
    table.cell(t, 1, 6, mssStatus, bgcolor=mssBg, text_color=color.white, text_size=size.small)
    
    // OTE Zone
    table.cell(t, 0, 7, "OTE Zone", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 7, "62-70.5-79%", bgcolor=color.new(color.purple, 70), text_color=color.white, text_size=size.small)

// ==================== ALERTS ====================
alertcondition(bull_EntrySignal, "Bullish OTE Entry", "LONG OTE Entry Signal - Price in 0.62-0.79 zone")
alertcondition(bear_EntrySignal, "Bearish OTE Entry", "SHORT OTE Entry Signal - Price in 0.62-0.79 zone")
alertcondition(bullFVG, "Bullish FVG", "Bullish Fair Value Gap Detected")
alertcondition(bearFVG, "Bearish FVG", "Bearish Fair Value Gap Detected")
alertcondition(bullMSS, "Bullish MSS", "Bullish Market Structure Shift")
alertcondition(bearMSS, "Bearish MSS", "Bearish Market Structure Shift")

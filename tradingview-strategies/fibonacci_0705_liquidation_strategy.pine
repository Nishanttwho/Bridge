//@version=5
strategy("Fibonacci 0.705 Liquidation Strategy", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// ============================================================================
// LIQUIDATION-BASED FIBONACCI 0.705 STRATEGY
// 
// LOGIC (BULLISH):
// 1. Detect small pivot low in uptrend
// 2. Wait for LIQUIDATION (price goes below pivot low)
// 3. After liquidation, wait for swing high to form
// 4. Draw Fibonacci from liquidation low → swing high
// 5. Entry zone = 0.705 to 0.69 retracement
// 6. Entry ONLY when:
//    - Price TAPS zone (wick allowed)
//    - Candle closes BULLISH (close > open)
//    - Candle closes >= 0.69 (zone low) - CRITICAL!
// 7. SL = below entry candle low
// 8. TP = swing high
//
// BEARISH: Opposite logic
// ============================================================================

// Inputs
pivotLength = input.int(5, "Pivot Length", minval=2, maxval=15)
fibHigh = input.float(0.705, "Fib Zone High", step=0.001)
fibLow = input.float(0.69, "Fib Zone Low", step=0.001)
showPivots = input.bool(true, "Show Pivot Points")
trendFilterMA = input.int(50, "Trend MA Length", minval=10)
webhookUrl = input.string("https://your-replit-app.replit.dev/api/webhook", "Webhook URL")

// Trend filter
ma = ta.ema(close, trendFilterMA)
uptrend = close > ma and ma > ma[5]
downtrend = close < ma and ma < ma[5]

// Detect pivots
pivotH = ta.pivothigh(high, pivotLength, pivotLength)
pivotL = ta.pivotlow(low, pivotLength, pivotLength)

// ============================================================================
// BUY SETUP (Liquidation-based)
// ============================================================================

var float buy_SmallPivotLow = na
var int buy_SmallPivotBar = na
var float buy_LiquidationLow = na
var int buy_LiquidationBar = na
var float buy_SwingHigh = na
var int buy_SwingHighBar = na
var bool buy_SetupActive = false

// Step 1: Mark small pivot low (in uptrend)
if not na(pivotL) and uptrend and na(buy_SmallPivotLow)
    buy_SmallPivotLow := pivotL[pivotLength]
    buy_SmallPivotBar := bar_index - pivotLength

// Step 2: Check for LIQUIDATION (price goes below small pivot low)
if not na(buy_SmallPivotLow) and low < buy_SmallPivotLow and na(buy_LiquidationLow)
    buy_LiquidationLow := low
    buy_LiquidationBar := bar_index
    buy_SmallPivotLow := na  // Reset
    buy_SwingHigh := na

// Step 3: After liquidation, wait for swing high
if not na(buy_LiquidationLow) and na(buy_SwingHigh) and not na(pivotH)
    buy_SwingHigh := pivotH[pivotLength]
    buy_SwingHighBar := bar_index - pivotLength
    buy_SetupActive := true

// Calculate Fibonacci zone
float buy_FibZoneHigh = na
float buy_FibZoneLow = na
float buy_FibRange = na

if buy_SetupActive and not na(buy_LiquidationLow) and not na(buy_SwingHigh)
    buy_FibRange := buy_SwingHigh - buy_LiquidationLow
    buy_FibZoneHigh := buy_LiquidationLow + (buy_FibRange * fibHigh)  // 0.705
    buy_FibZoneLow := buy_LiquidationLow + (buy_FibRange * fibLow)    // 0.69

// Entry logic - EXACT conditions
bool buy_ZoneTapped = buy_SetupActive and not na(buy_FibZoneLow) and not na(buy_FibZoneHigh) and
                      low <= buy_FibZoneHigh and low >= buy_LiquidationLow

bool buy_BullishClose = close > open  // Bullish candle

bool buy_CloseAboveZoneLow = close >= buy_FibZoneLow  // CRITICAL: Must close >= 0.69

bool buy_Entry = buy_ZoneTapped and buy_BullishClose and buy_CloseAboveZoneLow and strategy.position_size == 0

if buy_Entry
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", "Long", stop=low, limit=buy_SwingHigh)
    
    // Webhook
    alert('{"symbol":"' + syminfo.ticker + '","type":"BUY","indicator":"fib_705_liq","entry":"' + str.tostring(close) + '","stopLoss":"' + str.tostring(low) + '","takeProfit":"' + str.tostring(buy_SwingHigh) + '"}', alert.freq_once_per_bar)
    
    // Reset
    buy_SetupActive := false
    buy_LiquidationLow := na
    buy_SwingHigh := na

// Reset if new lower low breaks structure
if buy_SetupActive and not na(pivotL) and pivotL[pivotLength] < buy_LiquidationLow
    buy_SetupActive := false
    buy_LiquidationLow := na
    buy_SwingHigh := na
    buy_SmallPivotLow := na

// ============================================================================
// SELL SETUP (Liquidation-based)
// ============================================================================

var float sell_SmallPivotHigh = na
var int sell_SmallPivotBar = na
var float sell_LiquidationHigh = na
var int sell_LiquidationBar = na
var float sell_SwingLow = na
var int sell_SwingLowBar = na
var bool sell_SetupActive = false

// Step 1: Mark small pivot high (in downtrend)
if not na(pivotH) and downtrend and na(sell_SmallPivotHigh)
    sell_SmallPivotHigh := pivotH[pivotLength]
    sell_SmallPivotBar := bar_index - pivotLength

// Step 2: Check for LIQUIDATION (price goes above small pivot high)
if not na(sell_SmallPivotHigh) and high > sell_SmallPivotHigh and na(sell_LiquidationHigh)
    sell_LiquidationHigh := high
    sell_LiquidationBar := bar_index
    sell_SmallPivotHigh := na  // Reset
    sell_SwingLow := na

// Step 3: After liquidation, wait for swing low
if not na(sell_LiquidationHigh) and na(sell_SwingLow) and not na(pivotL)
    sell_SwingLow := pivotL[pivotLength]
    sell_SwingLowBar := bar_index - pivotLength
    sell_SetupActive := true

// Calculate Fibonacci zone
float sell_FibZoneHigh = na
float sell_FibZoneLow = na
float sell_FibRange = na

if sell_SetupActive and not na(sell_LiquidationHigh) and not na(sell_SwingLow)
    sell_FibRange := sell_LiquidationHigh - sell_SwingLow
    sell_FibZoneLow := sell_LiquidationHigh - (sell_FibRange * fibHigh)   // 0.705
    sell_FibZoneHigh := sell_LiquidationHigh - (sell_FibRange * fibLow)   // 0.69

// Entry logic - EXACT conditions
bool sell_ZoneTapped = sell_SetupActive and not na(sell_FibZoneLow) and not na(sell_FibZoneHigh) and
                       high >= sell_FibZoneLow and high <= sell_LiquidationHigh

bool sell_BearishClose = close < open  // Bearish candle

bool sell_CloseBelowZoneHigh = close <= sell_FibZoneHigh  // CRITICAL: Must close <= 0.69

bool sell_Entry = sell_ZoneTapped and sell_BearishClose and sell_CloseBelowZoneHigh and strategy.position_size == 0

if sell_Entry
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", "Short", stop=high, limit=sell_SwingLow)
    
    // Webhook
    alert('{"symbol":"' + syminfo.ticker + '","type":"SELL","indicator":"fib_705_liq","entry":"' + str.tostring(close) + '","stopLoss":"' + str.tostring(high) + '","takeProfit":"' + str.tostring(sell_SwingLow) + '"}', alert.freq_once_per_bar)
    
    // Reset
    sell_SetupActive := false
    sell_LiquidationHigh := na
    sell_SwingLow := na

// Reset if new higher high breaks structure
if sell_SetupActive and not na(pivotH) and pivotH[pivotLength] > sell_LiquidationHigh
    sell_SetupActive := false
    sell_LiquidationHigh := na
    sell_SwingLow := na
    sell_SmallPivotHigh := na

// ============================================================================
// VISUALS
// ============================================================================

// Trend MA
plot(ma, "Trend MA", color.new(color.yellow, 50), 2)

// Show all pivots
plotshape(showPivots ? pivotL : na, "Pivot Low", shape.triangleup, location.belowbar, color.new(color.blue, 30), size=size.tiny)
plotshape(showPivots ? pivotH : na, "Pivot High", shape.triangledown, location.abovebar, color.new(color.orange, 30), size=size.tiny)

// BUY Setup - Liquidation point and Swing High
plot(buy_SetupActive ? buy_LiquidationLow : na, "Liquidation Low", color.new(color.red, 0), 3, plot.style_cross)
plot(buy_SetupActive ? buy_SwingHigh : na, "Swing High", color.new(color.lime, 0), 3, plot.style_cross)

// BUY Fib Zone (0.705 - 0.69)
plot(buy_SetupActive ? buy_FibZoneHigh : na, "0.705 Level", color.new(color.aqua, 0), 2)
plot(buy_SetupActive ? buy_FibZoneLow : na, "0.69 Level", color.new(color.aqua, 0), 2)

buy_ZoneTop = plot(buy_SetupActive ? buy_FibZoneHigh : na, color=na)
buy_ZoneBottom = plot(buy_SetupActive ? buy_FibZoneLow : na, color=na)
fill(buy_ZoneTop, buy_ZoneBottom, color.new(color.aqua, 85), title="BUY Entry Zone")

// SELL Setup - Liquidation point and Swing Low
plot(sell_SetupActive ? sell_LiquidationHigh : na, "Liquidation High", color.new(color.lime, 0), 3, plot.style_cross)
plot(sell_SetupActive ? sell_SwingLow : na, "Swing Low", color.new(color.red, 0), 3, plot.style_cross)

// SELL Fib Zone (0.705 - 0.69)
plot(sell_SetupActive ? sell_FibZoneLow : na, "0.705 Level", color.new(color.fuchsia, 0), 2)
plot(sell_SetupActive ? sell_FibZoneHigh : na, "0.69 Level", color.new(color.fuchsia, 0), 2)

sell_ZoneTop = plot(sell_SetupActive ? sell_FibZoneHigh : na, color=na)
sell_ZoneBottom = plot(sell_SetupActive ? sell_FibZoneLow : na, color=na)
fill(sell_ZoneTop, sell_ZoneBottom, color.new(color.fuchsia, 85), title="SELL Entry Zone")

// Entry Labels
if buy_Entry
    label.new(bar_index, low, "🚀 LONG ENTRY\nEntry: " + str.tostring(close, "#.####") + 
              "\nSL: " + str.tostring(low, "#.####") + 
              "\nTP: " + str.tostring(buy_SwingHigh, "#.####") + 
              "\nR:R = " + str.tostring((buy_SwingHigh - close) / (close - low), "#.##"), 
              color=color.new(color.green, 0), textcolor=color.white, style=label.style_label_up, size=size.normal)

if sell_Entry
    label.new(bar_index, high, "🔻 SHORT ENTRY\nEntry: " + str.tostring(close, "#.####") + 
              "\nSL: " + str.tostring(high, "#.####") + 
              "\nTP: " + str.tostring(sell_SwingLow, "#.####") + 
              "\nR:R = " + str.tostring((close - sell_SwingLow) / (high - close), "#.##"), 
              color=color.new(color.red, 0), textcolor=color.white, style=label.style_label_down, size=size.normal)

// Background for active setups
bgcolor(buy_SetupActive ? color.new(color.green, 95) : na)
bgcolor(sell_SetupActive ? color.new(color.red, 95) : na)

// Status Table
var table statusTable = table.new(position.top_right, 2, 5, border_width=1)

if barstate.islast
    table.cell(statusTable, 0, 0, "STATUS", bgcolor=color.new(color.gray, 70), text_color=color.white)
    table.cell(statusTable, 1, 0, "VALUE", bgcolor=color.new(color.gray, 70), text_color=color.white)
    
    table.cell(statusTable, 0, 1, "Trend", text_color=color.white)
    table.cell(statusTable, 1, 1, uptrend ? "UP ✅" : downtrend ? "DOWN ✅" : "NEUTRAL", 
              bgcolor=uptrend ? color.new(color.green, 70) : downtrend ? color.new(color.red, 70) : color.new(color.gray, 80), 
              text_color=color.white)
    
    table.cell(statusTable, 0, 2, "BUY Setup", text_color=color.white)
    table.cell(statusTable, 1, 2, buy_SetupActive ? "ACTIVE 🎯" : "Waiting...", 
              bgcolor=buy_SetupActive ? color.new(color.green, 70) : color.new(color.gray, 80), 
              text_color=color.white)
    
    table.cell(statusTable, 0, 3, "SELL Setup", text_color=color.white)
    table.cell(statusTable, 1, 3, sell_SetupActive ? "ACTIVE 🎯" : "Waiting...", 
              bgcolor=sell_SetupActive ? color.new(color.red, 70) : color.new(color.gray, 80), 
              text_color=color.white)
    
    table.cell(statusTable, 0, 4, "Fib Zone", text_color=color.white)
    table.cell(statusTable, 1, 4, str.tostring(fibHigh, "#.###") + " - " + str.tostring(fibLow, "#.###"), 
              bgcolor=color.new(color.blue, 70), text_color=color.white)

// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// Combined Algo Trading Indicator with Guardier 15m Trend Filter

//@version=5
indicator('ALGO + GUARDIER 15M FILTER', 'ALGO_GUARD', overlay=true, format=format.price, precision=2)

// ============================================================================
// INPUTS
// ============================================================================

// Algo Trading Settings
src = close  // Default source
atrPeriod = 10
atrMultiplier = 3.0
t3Length = 10
t3VolumeFactor = 0.7

// Symbol-specific settings (can be customized)
if syminfo.ticker == "FROTO"
    src := high
    atrPeriod := 34
    atrMultiplier := 4.0
    t3Length := 36
    t3VolumeFactor := 0.5
else if syminfo.ticker == "TUPRS"
    src := close
    atrPeriod := 15
    atrMultiplier := 3.4
    t3Length := 25
    t3VolumeFactor := 0.9
else if syminfo.ticker == "KCHOL"
    src := open
    atrPeriod := 12
    atrMultiplier := 3.2
    t3Length := 11
    t3VolumeFactor := 0.7
else if syminfo.ticker == "ADAUSDT"
    src := hl2
    atrPeriod := 3
    atrMultiplier := 0.1
    t3Length := 9
    t3VolumeFactor := 0.7
else if syminfo.ticker == "XRPUSDT"
    src := low
    atrPeriod := 3
    atrMultiplier := 0.1
    t3Length := 11
    t3VolumeFactor := 0.7
else if syminfo.ticker == "YKBNK"
    src := hlc3
    atrPeriod := 15
    atrMultiplier := 5.5
    t3Length := 13
    t3VolumeFactor := 0.9

// Display Settings
show_15m_trend = input.bool(true, "Show 15m Trend Table", group="Display Settings")
show_signals = input.bool(true, "Show Buy/Sell Labels", group="Display Settings")

// ============================================================================
// GUARDIER 15M TREND DETECTION
// ============================================================================

// Simple trend detection function
getTrend() =>
    // Use EMA crossover for trend
    ema_fast = ta.ema(close, 8)
    ema_slow = ta.ema(close, 21)
    
    trend_value = 0
    if ema_fast > ema_slow
        trend_value := 1  // Bullish
    else if ema_fast < ema_slow
        trend_value := -1  // Bearish
    
    trend_value

// Get 15-minute trend
itrend15m = request.security(syminfo.tickerid, "15", getTrend(), lookahead=barmerge.lookahead_on)

// ============================================================================
// ALGO TRADING SIGNALS
// ============================================================================

// T3 calculation
T3_Func(source, length, vFactor) =>
    ema1 = ta.ema(source, length)
    ema2 = ta.ema(ema1, length)
    ema3 = ta.ema(ema2, length)
    ema4 = ta.ema(ema3, length)
    ema5 = ta.ema(ema4, length)
    ema6 = ta.ema(ema5, length)
    
    c1 = -vFactor * vFactor * vFactor
    c2 = 3 * vFactor * vFactor + 3 * vFactor * vFactor * vFactor
    c3 = -6 * vFactor * vFactor - 3 * vFactor - 3 * vFactor * vFactor * vFactor
    c4 = 1 + 3 * vFactor + vFactor * vFactor * vFactor + 3 * vFactor * vFactor
    
    t3_value = c1 * ema6 + c2 * ema5 + c3 * ema4 + c4 * ema3
    t3_value

T3 = T3_Func(src, t3Length, t3VolumeFactor)

// ATR calculation and trend lines
atr = ta.atr(atrPeriod)
up = T3 - atrMultiplier * atr
up1 = nz(up[1], up)
up := close[1] > up1 ? math.max(up, up1) : up

dn = T3 + atrMultiplier * atr
dn1 = nz(dn[1], dn)
dn := close[1] < dn1 ? math.min(dn, dn1) : dn

// Determine current trend
var int algoTrend = 1
algoTrend := nz(algoTrend[1], algoTrend)
algoTrend := algoTrend == -1 and close > dn1 ? 1 : algoTrend == 1 and close < up1 ? -1 : algoTrend

// Raw Buy and Sell signals (before filtering)
rawBuySignal = algoTrend == 1 and algoTrend[1] == -1
rawSellSignal = algoTrend == -1 and algoTrend[1] == 1

// ============================================================================
// FILTERED SIGNALS (WITH 15M TREND FILTER)
// ============================================================================

// Only allow BUY when 15m trend is BULLISH (1)
// Only allow SELL when 15m trend is BEARISH (-1)
buySignal = rawBuySignal and itrend15m == 1
sellSignal = rawSellSignal and itrend15m == -1

// ============================================================================
// PLOTTING
// ============================================================================

// Plot trend lines
upPlot = plot(algoTrend == 1 ? up : na, title='Up Trend', color=color.new(color.green, 5), linewidth=3, style=plot.style_linebr)
dnPlot = plot(algoTrend == 1 ? na : dn, title='Down Trend', style=plot.style_linebr, linewidth=3, color=color.new(color.red, 5))

// Plot signals
plotshape(show_signals and buySignal ? up : na, title='Buy', text='BUY', location=location.absolute, style=shape.labelup, color=color.new(color.green, 0), textcolor=color.white, size=size.normal)
plotshape(show_signals and sellSignal ? dn : na, title='Sell', text='SELL', location=location.absolute, style=shape.labeldown, color=color.new(color.red, 0), textcolor=color.white, size=size.normal)

// ============================================================================
// 15M TREND TABLE DISPLAY
// ============================================================================

if show_15m_trend
    var table trendTable = table.new(position=position.top_right, columns=2, rows=2, bgcolor=color.new(color.black, 80), frame_width=1, border_width=1)
    
    if barstate.islast
        // Header
        table.cell(trendTable, 0, 0, "15M TREND", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.gray, 50))
        
        // Trend value
        trendText = itrend15m == 1 ? "BULLISH" : itrend15m == -1 ? "BEARISH" : "NEUTRAL"
        trendColor = itrend15m == 1 ? color.new(color.green, 0) : itrend15m == -1 ? color.new(color.red, 0) : color.new(color.gray, 0)
        table.cell(trendTable, 0, 1, trendText, text_color=color.white, text_size=size.large, bgcolor=trendColor)

// ============================================================================
// WEBHOOK ALERTS
// ============================================================================

if buySignal
    alertMessage = '{\n' + 
         '  "symbol": "' + syminfo.ticker + '",\n' + 
         '  "type": "BUY",\n' + 
         '  "indicator": "algo_guardier",\n' + 
         '  "price": "' + str.tostring(close) + '"\n' + 
         '}'
    alert(alertMessage, alert.freq_once_per_bar_close)

if sellSignal
    alertMessage = '{\n' + 
         '  "symbol": "' + syminfo.ticker + '",\n' + 
         '  "type": "SELL",\n' + 
         '  "indicator": "algo_guardier",\n' + 
         '  "price": "' + str.tostring(close) + '"\n' + 
         '}'
    alert(alertMessage, alert.freq_once_per_bar_close)

// Simple alert conditions for testing
alertcondition(buySignal, title='Filtered Buy Signal', message='BUY Signal (15m Trend: BULLISH)')
alertcondition(sellSignal, title='Filtered Sell Signal', message='SELL Signal (15m Trend: BEARISH)')

// Combined Algo Trading Indicator with Guardier 15m Trend Filter

//@version=5
indicator('ALGO + GUARDIER 15M FILTER', 'ALGO_GUARD', overlay=true, format=format.price, precision=2)

// ============================================================================
// INPUTS
// ============================================================================

// Algo Trading Settings
symbolSource() =>
    switch syminfo.ticker
        "FROTO" => high
        "TUPRS" => close
        "KCHOL" => open
        "ADAUSDT" => hl2
        "XRPUSDT" => low
        "YKBNK" => hlc3
        => close

symbolSettings() =>
    switch syminfo.ticker
        "FROTO" => [34, 4.0, 36, 0.5]
        "TUPRS" => [15, 3.4, 25, 0.9]
        "KCHOL" => [12, 3.2, 11, 0.7]
        "ADAUSDT" => [3, 0.1, 9, 0.7]
        "XRPUSDT" => [3, 0.1, 11, 0.7]
        "YKBNK" => [15, 5.5, 13, 0.9]
        => [10, 3.0, 10, 0.7]

src = symbolSource()
[atrPeriod, atrMultiplier, t3Length, t3VolumeFactor] = symbolSettings()

// Display Settings
show_15m_trend = input.bool(true, "Show 15m Trend Table", group="Display Settings")
show_signals = input.bool(true, "Show Buy/Sell Labels", group="Display Settings")

// ============================================================================
// GUARDIER 15M TREND DETECTION
// ============================================================================

// Market Structure function (simplified from Guardier)
internal_r_lookback = 5
swing_r_lookback = 50

// Calculate trend based on market structure
calcTrend() =>
    var int trend = 0
    
    // Calculate pivot points
    iH = ta.pivothigh(high, internal_r_lookback, internal_r_lookback)
    iL = ta.pivotlow(low, internal_r_lookback, internal_r_lookback)
    
    // Track highs and lows
    var float lastHigh = na
    var float lastLow = na
    
    if not na(iH)
        lastHigh := iH
    
    if not na(iL)
        lastLow := iL
    
    // Determine trend
    if not na(lastHigh) and not na(lastLow)
        if high > lastHigh
            trend := 1  // Bullish
        else if low < lastLow
            trend := -1 // Bearish
    
    trend

// Get 15-minute trend
itrend15m = request.security(syminfo.tickerid, "15", calcTrend(), lookahead=barmerge.lookahead_on)

// ============================================================================
// ALGO TRADING SIGNALS
// ============================================================================

// T3 calculation
T3_Func(src, length, T3a1) =>
    T3e1 = ta.ema(src, length)
    T3e2 = ta.ema(T3e1, length)
    T3e3 = ta.ema(T3e2, length)
    T3e4 = ta.ema(T3e3, length)
    T3e5 = ta.ema(T3e4, length)
    T3e6 = ta.ema(T3e5, length)
    T3c1 = -T3a1 * T3a1 * T3a1
    T3c2 = 3 * T3a1 * T3a1 + 3 * T3a1 * T3a1 * T3a1
    T3c3 = -6 * T3a1 * T3a1 - 3 * T3a1 - 3 * T3a1 * T3a1 * T3a1
    T3c4 = 1 + 3 * T3a1 + T3a1 * T3a1 * T3a1 + 3 * T3a1 * T3a1
    T3 = T3c1 * T3e6 + T3c2 * T3e5 + T3c3 * T3e4 + T3c4 * T3e3
    T3

T3 = T3_Func(src, t3Length, t3VolumeFactor)

// ATR calculation and trend lines
atr = ta.atr(atrPeriod)
up = T3 - atrMultiplier * atr
up1 = nz(up[1], up)
up := close[1] > up1 ? math.max(up, up1) : up
dn = T3 + atrMultiplier * atr
dn1 = nz(dn[1], dn)
dn := close[1] < dn1 ? math.min(dn, dn1) : dn

trend = 1
trend := nz(trend[1], trend)
trend := trend == -1 and close > dn1 ? 1 : trend == 1 and close < up1 ? -1 : trend

// Raw Buy and Sell signals (before filtering)
rawBuySignal = trend == 1 and trend[1] == -1
rawSellSignal = trend == -1 and trend[1] == 1

// ============================================================================
// FILTERED SIGNALS (WITH 15M TREND FILTER)
// ============================================================================

// Only allow BUY when 15m trend is BULLISH (1)
// Only allow SELL when 15m trend is BEARISH (-1)
buySignal = rawBuySignal and itrend15m == 1
sellSignal = rawSellSignal and itrend15m == -1

// ============================================================================
// CALCULATE ENTRY PRICE
// ============================================================================

var float buyEntry = na
var float sellEntry = na

if buySignal
    buyEntry := close

if sellSignal
    sellEntry := close

// ============================================================================
// PLOTTING
// ============================================================================

// Plot trend lines
upPlot = plot(trend == 1 ? up : na, title='Up Trend', color=color.new(color.green, 5), linewidth=3, style=plot.style_linebr)
dnPlot = plot(trend == 1 ? na : dn, title='Down Trend', style=plot.style_linebr, linewidth=3, color=color.new(color.red, 5))

// Plot signals
if show_signals
    plotshape(buySignal ? up : na, title='Buy', text='BUY', location=location.absolute, style=shape.labelup, color=color.new(color.green, 0), textcolor=color.white, size=size.normal)
    plotshape(sellSignal ? dn : na, title='Sell', text='SELL', location=location.absolute, style=shape.labeldown, color=color.new(color.red, 0), textcolor=color.white, size=size.normal)

// ============================================================================
// 15M TREND TABLE DISPLAY
// ============================================================================

if show_15m_trend
    var table trendTable = table.new(position=position.top_right, columns=2, rows=2, bgcolor=color.new(color.black, 80), frame_width=1, border_width=1)
    
    if barstate.islast
        // Header
        table.cell(trendTable, 0, 0, "15M TREND", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.gray, 50))
        
        // Trend value
        trendText = itrend15m == 1 ? "BULLISH" : itrend15m == -1 ? "BEARISH" : "NEUTRAL"
        trendColor = itrend15m == 1 ? color.new(color.green, 0) : itrend15m == -1 ? color.new(color.red, 0) : color.new(color.gray, 0)
        table.cell(trendTable, 0, 1, trendText, text_color=color.white, text_size=size.large, bgcolor=trendColor)

// ============================================================================
// WEBHOOK ALERTS
// ============================================================================

if buySignal
    alertMessage = '{\n' + 
         '  "symbol": "' + syminfo.ticker + '",\n' + 
         '  "type": "BUY",\n' + 
         '  "indicator": "algo_guardier",\n' + 
         '  "price": "' + str.tostring(close) + '"\n' + 
         '}'
    alert(alertMessage, alert.freq_once_per_bar_close)

if sellSignal
    alertMessage = '{\n' + 
         '  "symbol": "' + syminfo.ticker + '",\n' + 
         '  "type": "SELL",\n' + 
         '  "indicator": "algo_guardier",\n' + 
         '  "price": "' + str.tostring(close) + '"\n' + 
         '}'
    alert(alertMessage, alert.freq_once_per_bar_close)

// Simple alert conditions for testing
alertcondition(buySignal, title='Filtered Buy Signal', message='BUY Signal (15m Trend: BULLISH)')
alertcondition(sellSignal, title='Filtered Sell Signal', message='SELL Signal (15m Trend: BEARISH)')

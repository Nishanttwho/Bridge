//@version=5
strategy("Fibonacci 0.705 Zone Retracement Strategy - FULL VISUALS", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, max_bars_back=500)

// ============================================================================
// STRATEGY LOGIC:
// 
// FOR BUY (Uptrend):
// 1. Detect pivot low → Mark it (waiting for liquidation)
// 2. Price LIQUIDATES that pivot (goes below it) → Mark liquidation point
// 3. After liquidation, wait for price to make new swing high → Mark swing high
// 4. Draw Fibonacci from liquidation low to swing high
// 5. Wait for retracement to 0.705-0.69 zone
// 6. Enter when candle taps zone and closes bullish
// 7. SL: Below entry candle | TP: The swing high
//
// FOR SELL: Opposite logic
// ============================================================================

// Inputs
pivotLength = input.int(5, "Pivot Length", minval=2, maxval=15)
fibHigh = input.float(0.705, "Fib Zone High", step=0.005)
fibLow = input.float(0.69, "Fib Zone Low", step=0.005)
showAllPivots = input.bool(true, "Show All Pivot Points")
showFibLevels = input.bool(true, "Show All Fib Levels")
webhookUrl = input.string("https://your-replit-app.replit.dev/api/webhook", "Webhook URL")
apiSecret = input.string("your-secret-key", "API Secret")

// Detect pivots
pivotH = ta.pivothigh(high, pivotLength, pivotLength)
pivotL = ta.pivotlow(low, pivotLength, pivotLength)

// State variables for BUY setup
var float buySetup_PivotLowToLiquidate = na
var int buySetup_PivotLowBar = na
var float buySetup_LiquidationLow = na
var int buySetup_LiquidationBar = na
var float buySetup_SwingHigh = na
var int buySetup_SwingHighBar = na
var bool buySetup_Active = false

// State variables for SELL setup
var float sellSetup_PivotHighToLiquidate = na
var int sellSetup_PivotHighBar = na
var float sellSetup_LiquidationHigh = na
var int sellSetup_LiquidationBar = na
var float sellSetup_SwingLow = na
var int sellSetup_SwingLowBar = na
var bool sellSetup_Active = false

// === BUY SETUP LOGIC ===

// Step 1: Mark pivot low for potential liquidation
if not na(pivotL) and not buySetup_Active
    buySetup_PivotLowToLiquidate := pivotL[pivotLength]
    buySetup_PivotLowBar := bar_index - pivotLength

// Step 2: Check if price liquidates the pivot low
if not na(buySetup_PivotLowToLiquidate) and not buySetup_Active and low < buySetup_PivotLowToLiquidate
    buySetup_LiquidationLow := low
    buySetup_LiquidationBar := bar_index
    buySetup_PivotLowToLiquidate := na
    buySetup_SwingHigh := na
    
// Step 3: After liquidation, wait for pivot high to form
if not na(buySetup_LiquidationLow) and na(buySetup_SwingHigh) and not na(pivotH)
    buySetup_SwingHigh := pivotH[pivotLength]
    buySetup_SwingHighBar := bar_index - pivotLength
    buySetup_Active := true

// Calculate BUY Fibonacci zone
float buyFibZoneHigh = na
float buyFibZoneLow = na
float buyFib_100 = na
float buyFib_786 = na
float buyFib_618 = na
float buyFib_50 = na
float buyFib_382 = na
float buyFib_236 = na
float buyFib_0 = na

if buySetup_Active and not na(buySetup_LiquidationLow) and not na(buySetup_SwingHigh)
    float priceRange = buySetup_SwingHigh - buySetup_LiquidationLow
    buyFibZoneHigh := buySetup_LiquidationLow + (priceRange * fibHigh)
    buyFibZoneLow := buySetup_LiquidationLow + (priceRange * fibLow)
    
    buyFib_100 := buySetup_SwingHigh
    buyFib_786 := buySetup_LiquidationLow + (priceRange * 0.786)
    buyFib_618 := buySetup_LiquidationLow + (priceRange * 0.618)
    buyFib_50 := buySetup_LiquidationLow + (priceRange * 0.5)
    buyFib_382 := buySetup_LiquidationLow + (priceRange * 0.382)
    buyFib_236 := buySetup_LiquidationLow + (priceRange * 0.236)
    buyFib_0 := buySetup_LiquidationLow

// BUY Entry logic
bool buyZoneTapped = buySetup_Active and not na(buyFibZoneLow) and not na(buyFibZoneHigh) and 
                 low <= buyFibZoneHigh and low >= buyFibZoneLow

bool buyValidClose = close > open and close >= buyFibZoneLow

bool buyEntry = buyZoneTapped and buyValidClose and strategy.position_size == 0

if buyEntry
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", "Long", stop=low, limit=buySetup_SwingHigh)
    
    // Webhook
    alert('{"symbol":"' + syminfo.ticker + '","type":"BUY","indicator":"fibonacci_705","entry":"' + str.tostring(close) + '","stopLoss":"' + str.tostring(low) + '","takeProfit":"' + str.tostring(buySetup_SwingHigh) + '"}', alert.freq_once_per_bar)
    
    // Reset BUY setup
    buySetup_Active := false
    buySetup_LiquidationLow := na
    buySetup_SwingHigh := na

// Reset BUY setup if structure breaks
if buySetup_Active and not na(pivotL) and pivotL[pivotLength] < buySetup_LiquidationLow
    buySetup_Active := false
    buySetup_LiquidationLow := na
    buySetup_SwingHigh := na

// === SELL SETUP LOGIC ===

// Step 1: Mark pivot high for potential liquidation
if not na(pivotH) and not sellSetup_Active
    sellSetup_PivotHighToLiquidate := pivotH[pivotLength]
    sellSetup_PivotHighBar := bar_index - pivotLength

// Step 2: Check if price liquidates the pivot high
if not na(sellSetup_PivotHighToLiquidate) and not sellSetup_Active and high > sellSetup_PivotHighToLiquidate
    sellSetup_LiquidationHigh := high
    sellSetup_LiquidationBar := bar_index
    sellSetup_PivotHighToLiquidate := na
    sellSetup_SwingLow := na

// Step 3: After liquidation, wait for pivot low to form
if not na(sellSetup_LiquidationHigh) and na(sellSetup_SwingLow) and not na(pivotL)
    sellSetup_SwingLow := pivotL[pivotLength]
    sellSetup_SwingLowBar := bar_index - pivotLength
    sellSetup_Active := true

// Calculate SELL Fibonacci zone
float sellFibZoneHigh = na
float sellFibZoneLow = na
float sellFib_100 = na
float sellFib_786 = na
float sellFib_618 = na
float sellFib_50 = na
float sellFib_382 = na
float sellFib_236 = na
float sellFib_0 = na

if sellSetup_Active and not na(sellSetup_LiquidationHigh) and not na(sellSetup_SwingLow)
    float priceRange = sellSetup_LiquidationHigh - sellSetup_SwingLow
    sellFibZoneHigh := sellSetup_LiquidationHigh - (priceRange * fibLow)
    sellFibZoneLow := sellSetup_LiquidationHigh - (priceRange * fibHigh)
    
    sellFib_100 := sellSetup_SwingLow
    sellFib_786 := sellSetup_LiquidationHigh - (priceRange * 0.786)
    sellFib_618 := sellSetup_LiquidationHigh - (priceRange * 0.618)
    sellFib_50 := sellSetup_LiquidationHigh - (priceRange * 0.5)
    sellFib_382 := sellSetup_LiquidationHigh - (priceRange * 0.382)
    sellFib_236 := sellSetup_LiquidationHigh - (priceRange * 0.236)
    sellFib_0 := sellSetup_LiquidationHigh

// SELL Entry logic
bool sellZoneTapped = sellSetup_Active and not na(sellFibZoneLow) and not na(sellFibZoneHigh) and 
                  high >= sellFibZoneLow and high <= sellFibZoneHigh

bool sellValidClose = close < open and close <= sellFibZoneHigh

bool sellEntry = sellZoneTapped and sellValidClose and strategy.position_size == 0

if sellEntry
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", "Short", stop=high, limit=sellSetup_SwingLow)
    
    // Webhook
    alert('{"symbol":"' + syminfo.ticker + '","type":"SELL","indicator":"fibonacci_705","entry":"' + str.tostring(close) + '","stopLoss":"' + str.tostring(high) + '","takeProfit":"' + str.tostring(sellSetup_SwingLow) + '"}', alert.freq_once_per_bar)
    
    // Reset SELL setup
    sellSetup_Active := false
    sellSetup_LiquidationHigh := na
    sellSetup_SwingLow := na

// Reset SELL setup if structure breaks
if sellSetup_Active and not na(pivotH) and pivotH[pivotLength] > sellSetup_LiquidationHigh
    sellSetup_Active := false
    sellSetup_LiquidationHigh := na
    sellSetup_SwingLow := na

// ============================================================================
// === FULL VISUAL SYSTEM ===
// ============================================================================

// 1. PLOT ALL PIVOT POINTS (MARKET STRUCTURE)
if showAllPivots
    plotshape(pivotL, "Pivot Low", shape.triangleup, location.belowbar, color.new(color.blue, 30), size=size.tiny)
    plotshape(pivotH, "Pivot High", shape.triangledown, location.abovebar, color.new(color.orange, 30), size=size.tiny)

// 2. SHOW PIVOT BEING TRACKED FOR LIQUIDATION (with horizontal line)
plot(not na(buySetup_PivotLowToLiquidate) ? buySetup_PivotLowToLiquidate : na, "Pivot Low Target", color.new(color.yellow, 0), 2, plot.style_cross)
plot(not na(sellSetup_PivotHighToLiquidate) ? sellSetup_PivotHighToLiquidate : na, "Pivot High Target", color.new(color.yellow, 0), 2, plot.style_cross)

// 3. MARK LIQUIDATION POINTS (Big X markers)
plotshape(not na(buySetup_LiquidationLow) and na(buySetup_LiquidationLow[1]), "LOW LIQUIDATED ⚡", shape.xcross, location.belowbar, color.new(color.red, 0), size=size.normal, text="LIQUIDATION")
plotshape(not na(sellSetup_LiquidationHigh) and na(sellSetup_LiquidationHigh[1]), "HIGH LIQUIDATED ⚡", shape.xcross, location.abovebar, color.new(color.lime, 0), size=size.normal, text="LIQUIDATION")

// 4. BUY SETUP - SWING HIGH & LIQUIDATION LOW
plot(buySetup_Active ? buySetup_SwingHigh : na, "Swing High (BUY)", color.new(color.lime, 0), 3, plot.style_circles)
plot(buySetup_Active ? buySetup_LiquidationLow : na, "Liquidation Low", color.new(color.red, 0), 3, plot.style_circles)

// 5. SELL SETUP - SWING LOW & LIQUIDATION HIGH  
plot(sellSetup_Active ? sellSetup_SwingLow : na, "Swing Low (SELL)", color.new(color.red, 0), 3, plot.style_circles)
plot(sellSetup_Active ? sellSetup_LiquidationHigh : na, "Liquidation High", color.new(color.lime, 0), 3, plot.style_circles)

// 6. BUY FIBONACCI LEVELS (All levels with labels)
if showFibLevels
    plot(buySetup_Active ? buyFib_100 : na, "Fib 1.0 (100%)", color.new(color.lime, 0), 1, plot.style_line)
    plot(buySetup_Active ? buyFib_786 : na, "Fib 0.786", color.new(color.purple, 40), 1, plot.style_line)
    plot(buySetup_Active ? buyFib_618 : na, "Fib 0.618", color.new(color.orange, 40), 1, plot.style_line)
    plot(buySetup_Active ? buyFib_50 : na, "Fib 0.5", color.new(color.gray, 40), 1, plot.style_line)
    plot(buySetup_Active ? buyFib_382 : na, "Fib 0.382", color.new(color.blue, 40), 1, plot.style_line)
    plot(buySetup_Active ? buyFib_236 : na, "Fib 0.236", color.new(color.teal, 40), 1, plot.style_line)
    plot(buySetup_Active ? buyFib_0 : na, "Fib 0.0 (0%)", color.new(color.red, 0), 1, plot.style_line)

// 7. ENTRY ZONE (0.705-0.69) - HIGHLIGHTED
plot(buySetup_Active ? buyFibZoneHigh : na, "Entry Zone High (0.705)", color.new(color.aqua, 0), 3)
plot(buySetup_Active ? buyFibZoneLow : na, "Entry Zone Low (0.69)", color.new(color.aqua, 0), 3)

buyZonePlotHigh = plot(buySetup_Active ? buyFibZoneHigh : na, color=na)
buyZonePlotLow = plot(buySetup_Active ? buyFibZoneLow : na, color=na)
fill(buyZonePlotHigh, buyZonePlotLow, color.new(color.aqua, 85), title="BUY Entry Zone")

// 8. SELL FIBONACCI LEVELS (All levels)
if showFibLevels
    plot(sellSetup_Active ? sellFib_100 : na, "Fib 1.0 (100%)", color.new(color.red, 0), 1, plot.style_line)
    plot(sellSetup_Active ? sellFib_786 : na, "Fib 0.786", color.new(color.purple, 40), 1, plot.style_line)
    plot(sellSetup_Active ? sellFib_618 : na, "Fib 0.618", color.new(color.orange, 40), 1, plot.style_line)
    plot(sellSetup_Active ? sellFib_50 : na, "Fib 0.5", color.new(color.gray, 40), 1, plot.style_line)
    plot(sellSetup_Active ? sellFib_382 : na, "Fib 0.382", color.new(color.blue, 40), 1, plot.style_line)
    plot(sellSetup_Active ? sellFib_236 : na, "Fib 0.236", color.new(color.teal, 40), 1, plot.style_line)
    plot(sellSetup_Active ? sellFib_0 : na, "Fib 0.0 (0%)", color.new(color.lime, 0), 1, plot.style_line)

// 9. SELL ENTRY ZONE (0.705-0.69) - HIGHLIGHTED
plot(sellSetup_Active ? sellFibZoneHigh : na, "Entry Zone High (0.69)", color.new(color.fuchsia, 0), 3)
plot(sellSetup_Active ? sellFibZoneLow : na, "Entry Zone Low (0.705)", color.new(color.fuchsia, 0), 3)

sellZonePlotHigh = plot(sellSetup_Active ? sellFibZoneHigh : na, color=na)
sellZonePlotLow = plot(sellSetup_Active ? sellFibZoneLow : na, color=na)
fill(sellZonePlotHigh, sellZonePlotLow, color.new(color.fuchsia, 85), title="SELL Entry Zone")

// 10. LABELS FOR KEY POINTS
if buySetup_Active and not na(buySetup_SwingHigh)
    label.new(bar_index, buySetup_SwingHigh, "SWING HIGH\n" + str.tostring(buySetup_SwingHigh, "#.####"), 
              color=color.new(color.lime, 20), textcolor=color.white, style=label.style_label_down, size=size.small)

if buySetup_Active and not na(buySetup_LiquidationLow)
    label.new(bar_index, buySetup_LiquidationLow, "LIQUIDATION LOW\n" + str.tostring(buySetup_LiquidationLow, "#.####"), 
              color=color.new(color.red, 20), textcolor=color.white, style=label.style_label_up, size=size.small)

if sellSetup_Active and not na(sellSetup_SwingLow)
    label.new(bar_index, sellSetup_SwingLow, "SWING LOW\n" + str.tostring(sellSetup_SwingLow, "#.####"), 
              color=color.new(color.red, 20), textcolor=color.white, style=label.style_label_up, size=size.small)

if sellSetup_Active and not na(sellSetup_LiquidationHigh)
    label.new(bar_index, sellSetup_LiquidationHigh, "LIQUIDATION HIGH\n" + str.tostring(sellSetup_LiquidationHigh, "#.####"), 
              color=color.new(color.lime, 20), textcolor=color.white, style=label.style_label_down, size=size.small)

// 11. ENTRY LABELS WITH FULL DETAILS
if buyEntry
    label.new(bar_index, low, "🔥 LONG ENTRY 🔥\n" + 
              "Entry: " + str.tostring(close, "#.####") + "\n" +
              "SL: " + str.tostring(low, "#.####") + "\n" +
              "TP: " + str.tostring(buySetup_SwingHigh, "#.####") + "\n" +
              "R:R = " + str.tostring((buySetup_SwingHigh - close) / (close - low), "#.##"), 
              color=color.new(color.green, 0), textcolor=color.white, style=label.style_label_up, size=size.normal)

if sellEntry
    label.new(bar_index, high, "🔥 SHORT ENTRY 🔥\n" + 
              "Entry: " + str.tostring(close, "#.####") + "\n" +
              "SL: " + str.tostring(high, "#.####") + "\n" +
              "TP: " + str.tostring(sellSetup_SwingLow, "#.####") + "\n" +
              "R:R = " + str.tostring((close - sellSetup_SwingLow) / (high - close), "#.##"), 
              color=color.new(color.red, 0), textcolor=color.white, style=label.style_label_down, size=size.normal)

// 12. BACKGROUND COLORING FOR ACTIVE SETUPS
bgcolor(buySetup_Active ? color.new(color.green, 95) : na, title="BUY Setup Active")
bgcolor(sellSetup_Active ? color.new(color.red, 95) : na, title="SELL Setup Active")

// 13. TABLE SHOWING SETUP STATUS (Top Right Corner)
var table statusTable = table.new(position.top_right, 2, 4, border_width=2)

if barstate.islast
    table.cell(statusTable, 0, 0, "STATUS", bgcolor=color.new(color.gray, 70), text_color=color.white, text_size=size.small)
    table.cell(statusTable, 1, 0, "VALUE", bgcolor=color.new(color.gray, 70), text_color=color.white, text_size=size.small)
    
    table.cell(statusTable, 0, 1, "BUY Setup", text_color=color.white, text_size=size.small)
    table.cell(statusTable, 1, 1, buySetup_Active ? "ACTIVE ✅" : "Waiting...", 
              bgcolor=buySetup_Active ? color.new(color.green, 70) : color.new(color.gray, 80), 
              text_color=color.white, text_size=size.small)
    
    table.cell(statusTable, 0, 2, "SELL Setup", text_color=color.white, text_size=size.small)
    table.cell(statusTable, 1, 2, sellSetup_Active ? "ACTIVE ✅" : "Waiting...", 
              bgcolor=sellSetup_Active ? color.new(color.red, 70) : color.new(color.gray, 80), 
              text_color=color.white, text_size=size.small)
    
    table.cell(statusTable, 0, 3, "Fib Zone", text_color=color.white, text_size=size.small)
    table.cell(statusTable, 1, 3, str.tostring(fibHigh, "#.###") + " - " + str.tostring(fibLow, "#.###"), 
              bgcolor=color.new(color.blue, 70), text_color=color.white, text_size=size.small)

//@version=5
strategy("Fibonacci 0.705 - 3 Candle Swing Strategy", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// ============================================================================
// 3-CANDLE SWING LOGIC:
// 
// SWING LOW (3 candles):
//   Candle 1 (middle): The swing low
//   Candle 2: Closes BELOW candle 1, but wick doesn't go ABOVE candle 1's high
//   Candle 3: Closes ABOVE candle 2, but wick doesn't go BELOW candle 2's low
//
// SWING HIGH (3 candles):
//   Candle 1 (middle): The swing high
//   Candle 2: Closes ABOVE candle 1, but wick doesn't go BELOW candle 1's low
//   Candle 3: Closes BELOW candle 2, but wick doesn't go ABOVE candle 2's high
//
// BULLISH ENTRY:
//   1. Find swing low → then swing high
//   2. Draw Fib from swing low to swing high
//   3. Wait for price to tap 0.705 level
//   4. Enter when price taps and closes bullish (rejection)
//   5. SL = below entry candle | TP = swing high
//
// BEARISH ENTRY: Opposite logic
// ============================================================================

// Inputs
fibLevel = input.float(0.705, "Fib Entry Level (0.705)", step=0.001, minval=0.5, maxval=0.9)
fibZoneRange = input.float(0.015, "Fib Zone Range (+/-)", step=0.001)
showSwings = input.bool(true, "Show Swing Points")
webhookUrl = input.string("https://your-replit-app.replit.dev/api/webhook", "Webhook URL")

// ============================================================================
// 3-CANDLE SWING DETECTION
// ============================================================================

// Detect 3-Candle Swing Low
// Candle[2] is middle, Candle[1] is second, Candle[0] is third (current)
bool swingLowDetected = 
     close[1] < close[2] and          // Candle 2 closes below candle 1 (middle)
     high[1] <= high[2] and           // Candle 2 doesn't wick above candle 1
     close[0] > close[1] and          // Candle 3 closes above candle 2
     low[0] >= low[1]                 // Candle 3 doesn't wick below candle 2

// Detect 3-Candle Swing High
bool swingHighDetected = 
     close[1] > close[2] and          // Candle 2 closes above candle 1 (middle)
     low[1] >= low[2] and             // Candle 2 doesn't wick below candle 1
     close[0] < close[1] and          // Candle 3 closes below candle 2
     high[0] <= high[1]               // Candle 3 doesn't wick above candle 2

// Store swing points
var float bullSwingLow = na
var int bullSwingLowBar = na
var float bullSwingHigh = na
var int bullSwingHighBar = na
var bool bullSetupActive = false

var float bearSwingHigh = na
var int bearSwingHighBar = na
var float bearSwingLow = na
var int bearSwingLowBar = na
var bool bearSetupActive = false

// ============================================================================
// BULLISH SETUP (Swing Low → Swing High)
// ============================================================================

// Step 1: Detect swing low
if swingLowDetected and not bullSetupActive
    bullSwingLow := low[2]
    bullSwingLowBar := bar_index - 2
    bullSwingHigh := na
    bullSetupActive := false

// Step 2: After swing low, detect swing high
if not na(bullSwingLow) and na(bullSwingHigh) and swingHighDetected
    bullSwingHigh := high[2]
    bullSwingHighBar := bar_index - 2
    bullSetupActive := true

// Calculate Fibonacci for BULL setup
float bullFibLevel = na
float bullFibZoneHigh = na
float bullFibZoneLow = na

if bullSetupActive and not na(bullSwingLow) and not na(bullSwingHigh)
    float priceRange = bullSwingHigh - bullSwingLow
    bullFibLevel := bullSwingLow + (priceRange * fibLevel)
    bullFibZoneHigh := bullFibLevel + (priceRange * fibZoneRange)
    bullFibZoneLow := bullFibLevel - (priceRange * fibZoneRange)

// BULL Entry Logic
bool bullZoneTapped = bullSetupActive and not na(bullFibZoneLow) and 
                      low <= bullFibZoneHigh and low >= bullFibZoneLow

bool bullValidClose = close > open  // Bullish candle (rejection)

bool bullEntry = bullZoneTapped and bullValidClose and strategy.position_size == 0

if bullEntry
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", "Long", stop=low, limit=bullSwingHigh)
    
    // Webhook alert
    alert('{"symbol":"' + syminfo.ticker + '","type":"BUY","indicator":"fib_705","entry":"' + str.tostring(close) + '","stopLoss":"' + str.tostring(low) + '","takeProfit":"' + str.tostring(bullSwingHigh) + '"}', alert.freq_once_per_bar)
    
    // Reset setup
    bullSetupActive := false
    bullSwingLow := na
    bullSwingHigh := na

// Reset if new swing low breaks structure
if bullSetupActive and swingLowDetected and low[2] < bullSwingLow
    bullSetupActive := false
    bullSwingLow := na
    bullSwingHigh := na

// ============================================================================
// BEARISH SETUP (Swing High → Swing Low)
// ============================================================================

// Step 1: Detect swing high
if swingHighDetected and not bearSetupActive
    bearSwingHigh := high[2]
    bearSwingHighBar := bar_index - 2
    bearSwingLow := na
    bearSetupActive := false

// Step 2: After swing high, detect swing low
if not na(bearSwingHigh) and na(bearSwingLow) and swingLowDetected
    bearSwingLow := low[2]
    bearSwingLowBar := bar_index - 2
    bearSetupActive := true

// Calculate Fibonacci for BEAR setup
float bearFibLevel = na
float bearFibZoneHigh = na
float bearFibZoneLow = na

if bearSetupActive and not na(bearSwingHigh) and not na(bearSwingLow)
    float priceRange = bearSwingHigh - bearSwingLow
    bearFibLevel := bearSwingHigh - (priceRange * fibLevel)
    bearFibZoneHigh := bearFibLevel + (priceRange * fibZoneRange)
    bearFibZoneLow := bearFibLevel - (priceRange * fibZoneRange)

// BEAR Entry Logic
bool bearZoneTapped = bearSetupActive and not na(bearFibZoneLow) and 
                      high >= bearFibZoneLow and high <= bearFibZoneHigh

bool bearValidClose = close < open  // Bearish candle (rejection)

bool bearEntry = bearZoneTapped and bearValidClose and strategy.position_size == 0

if bearEntry
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", "Short", stop=high, limit=bearSwingLow)
    
    // Webhook alert
    alert('{"symbol":"' + syminfo.ticker + '","type":"SELL","indicator":"fib_705","entry":"' + str.tostring(close) + '","stopLoss":"' + str.tostring(high) + '","takeProfit":"' + str.tostring(bearSwingLow) + '"}', alert.freq_once_per_bar)
    
    // Reset setup
    bearSetupActive := false
    bearSwingHigh := na
    bearSwingLow := na

// Reset if new swing high breaks structure
if bearSetupActive and swingHighDetected and high[2] > bearSwingHigh
    bearSetupActive := false
    bearSwingHigh := na
    bearSwingLow := na

// ============================================================================
// VISUALS
// ============================================================================

// Show Swing Points
plotshape(showSwings and swingLowDetected, "Swing Low", shape.triangleup, location.belowbar, color.new(color.blue, 0), size=size.small, text="SL")
plotshape(showSwings and swingHighDetected, "Swing High", shape.triangledown, location.abovebar, color.new(color.orange, 0), size=size.small, text="SH")

// BULL Setup Lines
plot(bullSetupActive ? bullSwingLow : na, "Bull Swing Low", color.new(color.green, 0), 2, plot.style_circles)
plot(bullSetupActive ? bullSwingHigh : na, "Bull Swing High", color.new(color.red, 0), 2, plot.style_circles)

// BULL Fib Zone
plot(bullSetupActive ? bullFibLevel : na, "Bull 0.705 Level", color.new(color.aqua, 0), 2)
bullZoneTop = plot(bullSetupActive ? bullFibZoneHigh : na, color=na)
bullZoneBottom = plot(bullSetupActive ? bullFibZoneLow : na, color=na)
fill(bullZoneTop, bullZoneBottom, color.new(color.aqua, 85), title="Bull Entry Zone")

// BEAR Setup Lines
plot(bearSetupActive ? bearSwingHigh : na, "Bear Swing High", color.new(color.red, 0), 2, plot.style_circles)
plot(bearSetupActive ? bearSwingLow : na, "Bear Swing Low", color.new(color.green, 0), 2, plot.style_circles)

// BEAR Fib Zone
plot(bearSetupActive ? bearFibLevel : na, "Bear 0.705 Level", color.new(color.fuchsia, 0), 2)
bearZoneTop = plot(bearSetupActive ? bearFibZoneHigh : na, color=na)
bearZoneBottom = plot(bearSetupActive ? bearFibZoneLow : na, color=na)
fill(bearZoneTop, bearZoneBottom, color.new(color.fuchsia, 85), title="Bear Entry Zone")

// Entry Labels
if bullEntry
    label.new(bar_index, low, "🚀 LONG\nEntry: " + str.tostring(close, "#.####") + "\nSL: " + str.tostring(low, "#.####") + "\nTP: " + str.tostring(bullSwingHigh, "#.####"), 
              color=color.new(color.green, 0), textcolor=color.white, style=label.style_label_up, size=size.normal)

if bearEntry
    label.new(bar_index, high, "🔻 SHORT\nEntry: " + str.tostring(close, "#.####") + "\nSL: " + str.tostring(high, "#.####") + "\nTP: " + str.tostring(bearSwingLow, "#.####"), 
              color=color.new(color.red, 0), textcolor=color.white, style=label.style_label_down, size=size.normal)

// Background color for active setups
bgcolor(bullSetupActive ? color.new(color.green, 95) : na, title="Bull Setup Active")
bgcolor(bearSetupActive ? color.new(color.red, 95) : na, title="Bear Setup Active")

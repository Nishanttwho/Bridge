//@version=5
indicator("Fibonacci 0.705 Liquidity Retracement", overlay=true, max_lines_count=500)

// ===========================
// INPUT SETTINGS
// ===========================

// Webhook Settings
webhookUrl = input.string("", title="Webhook URL", group="Webhook Settings")

// Strategy Settings
swingLookback = input.int(10, title="Swing Detection Lookback", minval=5, group="Strategy Settings")
fibLevel = input.float(0.705, title="Fibonacci Retracement Level", minval=0.5, maxval=0.8, step=0.005, group="Strategy Settings")

// Visual Settings
showSwingPoints = input.bool(true, title="Show Swing Points", group="Visual Settings")
showFibLevel = input.bool(true, title="Show 0.705 Level", group="Visual Settings")
showDealingRange = input.bool(true, title="Show Dealing Range", group="Visual Settings")

// Alert Settings
enableAlerts = input.bool(true, title="Enable Alerts", group="Alert Settings")

// ===========================
// SWING DETECTION
// ===========================

// Detect swing highs and lows
swingHigh = ta.pivothigh(high, swingLookback, swingLookback)
swingLow = ta.pivotlow(low, swingLookback, swingLookback)

// Store swing points
var float previousHigh = na
var float currentHigh = na
var int currentHighBar = na

var float previousLow = na
var float currentLow = na
var int currentLowBar = na

// Track the low before the high (for uptrend Fibonacci)
var float lowBeforeHigh = na
var int lowBeforeHighBar = na

// Track the high before the low (for downtrend Fibonacci)
var float highBeforeLow = na
var int highBeforeLowBar = na

// Update swing highs
if not na(swingHigh)
    previousHigh := currentHigh
    currentHigh := high[swingLookback]
    currentHighBar := bar_index - swingLookback

// Update swing lows
if not na(swingLow)
    previousLow := currentLow
    currentLow := low[swingLookback]
    currentLowBar := bar_index - swingLookback
    // When we get a new low, store it as potential base for next uptrend
    lowBeforeHigh := currentLow
    lowBeforeHighBar := currentLowBar

// When we get a new high, store the previous low as the base
if not na(swingHigh)
    // The low before this high is our Fibonacci starting point
    lowBeforeHigh := currentLow
    lowBeforeHighBar := currentLowBar

// When we get a new low, store the previous high as the base
if not na(swingLow)
    // The high before this low is our Fibonacci starting point
    highBeforeLow := currentHigh
    highBeforeLowBar := currentHighBar

// Plot swing points
plotshape(showSwingPoints and not na(swingHigh), "Swing High", shape.triangledown, location.abovebar, color.red, size=size.small)
plotshape(showSwingPoints and not na(swingLow), "Swing Low", shape.triangleup, location.belowbar, color.green, size=size.small)

// ===========================
// LIQUIDITY GRAB DETECTION
// ===========================

// Variables to track liquidity grab setup
var bool liquidityGrabbedUp = false
var float liquidityHigh = na
var float liquidityLow = na
var int liquidityLowBar = na
var float ote705Level = na

var bool liquidityGrabbedDown = false
var float liquidityLowLevel = na
var float liquidityHighLevel = na
var int liquidityHighBar = na
var float ote705LevelDown = na

// UPTREND: Detect when current high breaks previous high (liquidity grab)
if not na(currentHigh) and not na(previousHigh) and currentHigh > previousHigh
    // Liquidity grabbed! Now wait for retracement
    liquidityGrabbedUp := true
    liquidityHigh := currentHigh  // New high (TP target)
    liquidityLow := lowBeforeHigh  // Low before the break (Fib start)
    liquidityLowBar := lowBeforeHighBar
    
    // Calculate 0.705 retracement from low to new high
    swingRange = liquidityHigh - liquidityLow
    ote705Level := liquidityHigh - (swingRange * fibLevel)
    
    // Reset downtrend setup
    liquidityGrabbedDown := false

// DOWNTREND: Detect when current low breaks previous low (liquidity grab)
if not na(currentLow) and not na(previousLow) and currentLow < previousLow
    // Liquidity grabbed! Now wait for retracement
    liquidityGrabbedDown := true
    liquidityLowLevel := currentLow  // New low (TP target)
    liquidityHighLevel := highBeforeLow  // High before the break (Fib start)
    liquidityHighBar := highBeforeLowBar
    
    // Calculate 0.705 retracement from high to new low
    swingRange = liquidityHighLevel - liquidityLowLevel
    ote705LevelDown := liquidityLowLevel + (swingRange * fibLevel)
    
    // Reset uptrend setup
    liquidityGrabbedUp := false

// ===========================
// VISUAL DISPLAY
// ===========================

var line fibLevelLine = na
var line dealingHighLine = na
var line dealingLowLine = na

// Draw uptrend setup
if liquidityGrabbedUp and showFibLevel
    // Delete old lines
    if not na(fibLevelLine)
        line.delete(fibLevelLine)
    if not na(dealingHighLine)
        line.delete(dealingHighLine)
    if not na(dealingLowLine)
        line.delete(dealingLowLine)
    
    // Draw 0.705 level
    fibLevelLine := line.new(liquidityLowBar, ote705Level, bar_index + 20, ote705Level, color=color.new(color.yellow, 0), width=2, style=line.style_solid, extend=extend.right)
    
    if showDealingRange
        dealingHighLine := line.new(currentHighBar, liquidityHigh, bar_index + 20, liquidityHigh, color=color.new(color.green, 50), width=1, style=line.style_dashed, extend=extend.right)
        dealingLowLine := line.new(liquidityLowBar, liquidityLow, bar_index + 20, liquidityLow, color=color.new(color.green, 50), width=1, style=line.style_dashed, extend=extend.right)

// Draw downtrend setup
if liquidityGrabbedDown and showFibLevel
    // Delete old lines
    if not na(fibLevelLine)
        line.delete(fibLevelLine)
    if not na(dealingHighLine)
        line.delete(dealingHighLine)
    if not na(dealingLowLine)
        line.delete(dealingLowLine)
    
    // Draw 0.705 level
    fibLevelLine := line.new(liquidityHighBar, ote705LevelDown, bar_index + 20, ote705LevelDown, color=color.new(color.yellow, 0), width=2, style=line.style_solid, extend=extend.right)
    
    if showDealingRange
        dealingHighLine := line.new(liquidityHighBar, liquidityHighLevel, bar_index + 20, liquidityHighLevel, color=color.new(color.red, 50), width=1, style=line.style_dashed, extend=extend.right)
        dealingLowLine := line.new(currentLowBar, liquidityLowLevel, bar_index + 20, liquidityLowLevel, color=color.new(color.red, 50), width=1, style=line.style_dashed, extend=extend.right)

// ===========================
// ENTRY SIGNAL LOGIC
// ===========================

// BUY Signal: After liquidity grab up, price taps 0.705 and closes bullish
bool buySignal = false
float buyEntry = na
float buySL = na
float buyTP = na

if liquidityGrabbedUp and not na(ote705Level)
    // Check if price tapped 0.705 level
    tappedLevel = low <= ote705Level and low[1] > ote705Level
    
    // Check if closed bullish
    closedBullish = close > open
    
    // Must not close below 0.705
    didNotCloseBelow = close >= ote705Level
    
    if tappedLevel and closedBullish and didNotCloseBelow
        buySignal := true
        buyEntry := close
        buySL := low  // SL below entry candle
        buyTP := previousHigh  // TP at the previous high that was broken
        
        // Reset setup after signal
        liquidityGrabbedUp := false

// SELL Signal: After liquidity grab down, price taps 0.705 and closes bearish
bool sellSignal = false
float sellEntry = na
float sellSL = na
float sellTP = na

if liquidityGrabbedDown and not na(ote705LevelDown)
    // Check if price tapped 0.705 level
    tappedLevel = high >= ote705LevelDown and high[1] < ote705LevelDown
    
    // Check if closed bearish
    closedBearish = close < open
    
    // Must not close above 0.705
    didNotCloseAbove = close <= ote705LevelDown
    
    if tappedLevel and closedBearish and didNotCloseAbove
        sellSignal := true
        sellEntry := close
        sellSL := high  // SL above entry candle
        sellTP := previousLow  // TP at the previous low that was broken
        
        // Reset setup after signal
        liquidityGrabbedDown := false

// ===========================
// VISUAL SIGNALS
// ===========================

plotshape(buySignal, "BUY Signal", shape.labelup, location.belowbar, color.new(color.green, 0), text="BUY\n0.705", textcolor=color.white, size=size.normal)
plotshape(sellSignal, "SELL Signal", shape.labeldown, location.abovebar, color.new(color.red, 0), text="SELL\n0.705", textcolor=color.white, size=size.normal)

// Plot entry, SL, and TP lines
var line buyEntryLine = na
var line buySLLine = na
var line buyTPLine = na
var line sellEntryLine = na
var line sellSLLine = na
var line sellTPLine = na

if buySignal
    if not na(buyEntryLine)
        line.delete(buyEntryLine)
        line.delete(buySLLine)
        line.delete(buyTPLine)
    
    buyEntryLine := line.new(bar_index, buyEntry, bar_index + 10, buyEntry, color=color.blue, width=2, style=line.style_solid)
    buySLLine := line.new(bar_index, buySL, bar_index + 10, buySL, color=color.red, width=1, style=line.style_dashed)
    buyTPLine := line.new(bar_index, buyTP, bar_index + 10, buyTP, color=color.green, width=1, style=line.style_dashed)

if sellSignal
    if not na(sellEntryLine)
        line.delete(sellEntryLine)
        line.delete(sellSLLine)
        line.delete(sellTPLine)
    
    sellEntryLine := line.new(bar_index, sellEntry, bar_index + 10, sellEntry, color=color.blue, width=2, style=line.style_solid)
    sellSLLine := line.new(bar_index, sellSL, bar_index + 10, sellSL, color=color.red, width=1, style=line.style_dashed)
    sellTPLine := line.new(bar_index, sellTP, bar_index + 10, sellTP, color=color.green, width=1, style=line.style_dashed)

// ===========================
// WEBHOOK ALERTS
// ===========================

// BUY Alert
if buySignal and enableAlerts
    alertMessage = '{\n' + '  "symbol": "' + syminfo.ticker + '",\n' + '  "type": "BUY",\n' + '  "indicator": "fib_0705_liq",\n' + '  "entry": "' + str.tostring(buyEntry) + '",\n' + '  "stopLoss": "' + str.tostring(buySL) + '",\n' + '  "takeProfit": "' + str.tostring(buyTP) + '"\n' + '}'
    alert(alertMessage, alert.freq_once_per_bar_close)

// SELL Alert
if sellSignal and enableAlerts
    alertMessage = '{\n' + '  "symbol": "' + syminfo.ticker + '",\n' + '  "type": "SELL",\n' + '  "indicator": "fib_0705_liq",\n' + '  "entry": "' + str.tostring(sellEntry) + '",\n' + '  "stopLoss": "' + str.tostring(sellSL) + '",\n' + '  "takeProfit": "' + str.tostring(sellTP) + '"\n' + '}'
    alert(alertMessage, alert.freq_once_per_bar_close)

// ===========================
// INFORMATION TABLE
// ===========================

var table infoTable = table.new(position.top_right, 2, 6, bgcolor=color.new(color.gray, 90), border_width=1, border_color=color.gray)

if barstate.islast
    table.cell(infoTable, 0, 0, "Fib 0.705 Liquidity", text_color=color.white, text_size=size.normal)
    table.cell(infoTable, 1, 0, "", text_color=color.white)
    
    table.cell(infoTable, 0, 1, "Setup", text_color=color.white)
    table.cell(infoTable, 1, 1, liquidityGrabbedUp ? "BUY READY" : liquidityGrabbedDown ? "SELL READY" : "WAITING", text_color=liquidityGrabbedUp ? color.green : liquidityGrabbedDown ? color.red : color.gray)
    
    table.cell(infoTable, 0, 2, "Fib Level", text_color=color.white)
    table.cell(infoTable, 1, 2, str.tostring(fibLevel * 100) + "%", text_color=color.yellow)
    
    table.cell(infoTable, 0, 3, "0.705 Price", text_color=color.white)
    displayLevel = liquidityGrabbedUp ? ote705Level : liquidityGrabbedDown ? ote705LevelDown : na
    table.cell(infoTable, 1, 3, not na(displayLevel) ? str.tostring(displayLevel, format.mintick) : "N/A", text_color=color.yellow)
    
    table.cell(infoTable, 0, 4, "Target", text_color=color.white)
    displayTarget = liquidityGrabbedUp ? previousHigh : liquidityGrabbedDown ? previousLow : na
    table.cell(infoTable, 1, 4, not na(displayTarget) ? str.tostring(displayTarget, format.mintick) : "N/A", text_color=liquidityGrabbedUp ? color.green : color.red)
    
    table.cell(infoTable, 0, 5, "Alerts", text_color=color.white)
    table.cell(infoTable, 1, 5, enableAlerts ? "ON" : "OFF", text_color=enableAlerts ? color.green : color.red)
